<Application x:Class="WinDeploy.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WinDeploy.App.ViewModels"
             xmlns:views="clr-namespace:WinDeploy.App.Views"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <ResourceDictionary>

      <BooleanToVisibilityConverter x:Key="BoolToVis" />

      <!-- Palette -->
      <SolidColorBrush x:Key="PageBg" Color="#F5F5F2" />
      <SolidColorBrush x:Key="CardBg" Color="#FFFFFF" />
      <SolidColorBrush x:Key="BorderSoft" Color="#E6E6E1" />
      <SolidColorBrush x:Key="BorderStrong" Color="#D6D6D0" />
      <SolidColorBrush x:Key="TextPrimary" Color="#1B1B1A" />
      <SolidColorBrush x:Key="TextSecondary" Color="#6E6E69" />
      <SolidColorBrush x:Key="TextTertiary" Color="#9A9A93" />
      <SolidColorBrush x:Key="Accent" Color="#185FA5" />
      <SolidColorBrush x:Key="AccentBg" Color="#E6F1FB" />
      <SolidColorBrush x:Key="OkFg" Color="#3B6D11" />
      <SolidColorBrush x:Key="OkBg" Color="#EAF3DE" />
      <SolidColorBrush x:Key="FailFg" Color="#A32D2D" />
      <SolidColorBrush x:Key="FailBg" Color="#FCEBEB" />

      <!-- Base text -->
      <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
      </Style>

      <!-- Card -->
      <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBg}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
      </Style>

      <!-- Primary button -->
      <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Accent}" />
        <Setter Property="Background" Value="{StaticResource AccentBg}" />
        <Setter Property="BorderBrush" Value="#BBD4EE" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,7" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
        <Style.Triggers>
          <Trigger Property="IsEnabled" Value="False">
            <Setter Property="Opacity" Value="0.45" />
          </Trigger>
        </Style.Triggers>
      </Style>

      <!-- Small secondary button -->
      <Style x:Key="MiniButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        <Setter Property="Background" Value="{StaticResource CardBg}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}" />
        <Setter Property="Padding" Value="11,5" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
        <Style.Triggers>
          <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.4" /></Trigger>
        </Style.Triggers>
      </Style>

      <!-- Page → View map -->
      <DataTemplate DataType="{x:Type vm:InstallCenterViewModel}">
        <views:InstallCenterView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type vm:ProgressViewModel}">
        <views:ProgressView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type vm:ConfigSyncViewModel}">
        <views:ConfigSyncView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type vm:ExportViewModel}">
        <views:ExportView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
        <views:SettingsView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type vm:DetailViewModel}">
        <views:DetailView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type vm:PlaceholderViewModel}">
        <views:PlaceholderView />
      </DataTemplate>

    </ResourceDictionary>
  </Application.Resources>
</Application>
