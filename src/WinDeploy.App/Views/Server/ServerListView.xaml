<UserControl x:Class="WinDeploy.App.Views.Server.ServerListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="{DynamicResource S.nav.serviceConfig}" FontSize="20" FontWeight="SemiBold" />
      <TextBlock Text="{DynamicResource S.svc.view.listSubtitle}"
                 FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0" TextWrapping="Wrap" />
    </StackPanel>

    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
      <Button Content="{DynamicResource S.install.refresh}" Style="{StaticResource MiniButton}" Command="{Binding RefreshCommand}" />
      <TextBlock Text="{Binding Note}" FontSize="12" Foreground="{DynamicResource TextTertiary}"
                 VerticalAlignment="Center" Margin="14,0,0,0" TextWrapping="Wrap" MaxWidth="760" />
    </StackPanel>

    <!-- Margin right -24 / Padding right 24: scrollbar flush at the page's outer edge, content unchanged. -->
    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,14,-24,0" Padding="0,0,24,0">
      <StackPanel>
        <TextBlock Text="{DynamicResource S.svc.list.empty}"
                   FontSize="13" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"
                   Visibility="{Binding NoServers, Converter={StaticResource BoolToVis}}" />

        <ItemsControl ItemsSource="{Binding Servers}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Button Margin="0,0,0,10" HorizontalContentAlignment="Stretch" Cursor="Hand"
                      Command="{Binding DataContext.OpenCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                      CommandParameter="{Binding}">
                <Button.Template>
                  <ControlTemplate TargetType="Button">
                    <Border x:Name="B" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderSoft}"
                            BorderThickness="1" CornerRadius="10" Padding="16,13">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Width="40" Height="40" VerticalAlignment="Center">
                          <Border CornerRadius="9" Background="{DynamicResource AccentBg}"
                                  Visibility="{Binding NoIcon, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding KindTag}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource Accent}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                          </Border>
                          <Image Source="{Binding Icon}" Stretch="Uniform" Margin="2"
                                 RenderOptions.BitmapScalingMode="HighQuality"
                                 Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}" />
                        </Grid>

                        <StackPanel Grid.Column="1" Margin="14,0,12,0" VerticalAlignment="Center">
                          <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                          <TextBlock Text="{Binding Dir}" FontSize="11" FontFamily="Consolas" Foreground="{DynamicResource TextTertiary}"
                                     TextTrimming="CharacterEllipsis" Margin="0,2,0,0" ToolTip="{Binding Dir}" />
                          <TextBlock Text="{Binding Summary}" FontSize="11.5" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0" />
                        </StackPanel>

                        <Border Grid.Column="2" CornerRadius="7" Padding="9,3" VerticalAlignment="Center" Margin="0,0,10,0"
                                Background="{DynamicResource PageBg}">
                          <TextBlock Text="{Binding StatusText}" FontSize="12" FontWeight="SemiBold">
                            <TextBlock.Style>
                              <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource TextTertiary}" />
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding Running}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource OkFg}" />
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </TextBlock.Style>
                          </TextBlock>
                        </Border>

                        <TextBlock Grid.Column="3" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" />
                      </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="B" Property="BorderBrush" Value="{DynamicResource Accent}" />
                        <Setter TargetName="B" Property="Background" Value="{DynamicResource AccentBg}" />
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Button.Template>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
