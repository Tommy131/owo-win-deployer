<UserControl x:Class="WinDeploy.App.Views.Server.ServerDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit">
  <Grid Margin="24,16,24,16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- header -->
    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <Button Grid.Column="0" Style="{StaticResource MiniButton}" Command="{Binding BackCommand}" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
          <TextBlock Text="{DynamicResource S.common.back}" VerticalAlignment="Center" />
        </StackPanel>
      </Button>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
        <Grid Width="26" Height="26" VerticalAlignment="Center">
          <Border CornerRadius="6" Background="{DynamicResource AccentBg}"
                  Visibility="{Binding NoIcon, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding KindTag}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource Accent}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
          </Border>
          <Image Source="{Binding Icon}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"
                 Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}" />
        </Grid>
        <TextBlock Text="{Binding Name}" FontSize="19" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" />
      </StackPanel>
      <Button Grid.Column="2" Content="{DynamicResource S.svc.view.openInstallDir}" Style="{StaticResource MiniButton}" Command="{Binding OpenDirCommand}" VerticalAlignment="Center" />
    </Grid>

    <!-- status + service controls -->
    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="16,12" Margin="0,12,0,0"
            Visibility="{Binding HasService, Converter={StaticResource BoolToVis}}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- running badge -->
        <Border Grid.Column="0" CornerRadius="8" Padding="12,5" VerticalAlignment="Center" Background="{DynamicResource PageBg}">
          <StackPanel Orientation="Horizontal">
            <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,7,0">
              <Ellipse.Style>
                <Style TargetType="Ellipse">
                  <Setter Property="Fill" Value="{DynamicResource FailFg}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Running}" Value="True">
                      <Setter Property="Fill" Value="{DynamicResource OkFg}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Ellipse.Style>
            </Ellipse>
            <TextBlock Text="{Binding StatusText}" FontSize="13" FontWeight="SemiBold">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Foreground" Value="{DynamicResource FailFg}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Running}" Value="True">
                      <Setter Property="Foreground" Value="{DynamicResource OkFg}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </StackPanel>
        </Border>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
          <TextBlock Text="PID" FontSize="11" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" />
          <TextBlock Text="{Binding PidText}" FontSize="13" FontFamily="Consolas" Foreground="{DynamicResource TextPrimary}" Margin="6,0,16,0" VerticalAlignment="Center" />
          <TextBlock Text="{DynamicResource S.svc.view.uptime}" FontSize="11" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" />
          <TextBlock Text="{Binding UptimeText}" FontSize="13" Foreground="{DynamicResource TextPrimary}" Margin="6,0,0,0" VerticalAlignment="Center" />
        </StackPanel>

        <!-- action buttons -->
        <WrapPanel Grid.Column="3" VerticalAlignment="Center">
          <Button Content="{DynamicResource S.svc.action.start}" Style="{StaticResource OkButton}" Margin="6,0,0,0"
                  Visibility="{Binding ShowStart, Converter={StaticResource BoolToVis}}" Command="{Binding StartCommand}" />
          <Button Content="{DynamicResource S.svc.action.reload}" Style="{StaticResource InfoButton}" Margin="6,0,0,0"
                  Visibility="{Binding ShowReload, Converter={StaticResource BoolToVis}}" Command="{Binding ReloadCommand}" />
          <Button Content="{DynamicResource S.svc.action.restart}" Style="{StaticResource WarnButton}" Margin="6,0,0,0"
                  Visibility="{Binding ShowRestart, Converter={StaticResource BoolToVis}}" Command="{Binding RestartCommand}" />
          <Button Content="{DynamicResource S.svc.action.stop}" Style="{StaticResource DangerButton}" Margin="6,0,0,0"
                  Visibility="{Binding ShowStop, Converter={StaticResource BoolToVis}}" Command="{Binding StopCommand}" />
        </WrapPanel>
      </Grid>
    </Border>

    <!-- main: left management panel + right editor -->
    <Grid Grid.Row="2" Margin="0,12,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="390" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,12,0">
        <StackPanel>

          <!-- config files -->
          <TextBlock Text="{DynamicResource S.svc.view.configFiles}" FontSize="13" FontWeight="SemiBold" Margin="2,0,0,6" />
          <Border Style="{StaticResource Card}" Padding="10,8">
            <StackPanel>
              <ItemsControl ItemsSource="{Binding Configs}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button HorizontalContentAlignment="Left" Margin="0,0,0,3" Cursor="Hand"
                            Command="{Binding DataContext.OpenConfigCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding}">
                      <Button.Template>
                        <ControlTemplate TargetType="Button">
                          <Border x:Name="B" Background="{DynamicResource PageBg}" CornerRadius="6" Padding="9,6">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" Margin="0,0,7,0" />
                              <TextBlock Text="{Binding Name}" FontSize="12.5" FontFamily="Consolas" Foreground="{DynamicResource TextPrimary}" />
                            </StackPanel>
                          </Border>
                          <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                              <Setter TargetName="B" Property="Background" Value="{DynamicResource AccentBg}" />
                            </Trigger>
                          </ControlTemplate.Triggers>
                        </ControlTemplate>
                      </Button.Template>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- virtual hosts -->
          <Grid Margin="2,16,0,6" Visibility="{Binding SupportsVhost, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{DynamicResource S.svc.view.vhosts}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
              <Button Content="{DynamicResource S.svc.view.newVhost}" Style="{StaticResource MiniButton}" Command="{Binding CreateVhostCommand}" />
              <Button Content="{DynamicResource S.svc.view.dir}" Style="{StaticResource MiniButton}" Margin="6,0,0,0" Command="{Binding OpenVhostDirCommand}" />
            </StackPanel>
          </Grid>
          <Border Style="{StaticResource Card}" Padding="10,8" Visibility="{Binding SupportsVhost, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <TextBlock Text="{DynamicResource S.svc.view.noVhosts}" FontSize="11.5" Foreground="{DynamicResource TextTertiary}" TextWrapping="Wrap"
                         Visibility="{Binding Vhosts.Count, Converter={StaticResource ZeroToVis}}" />
              <ItemsControl ItemsSource="{Binding Vhosts}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{DynamicResource PageBg}" CornerRadius="6" Padding="9,6" Margin="0,0,0,4">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="12.5" FontFamily="Consolas" Foreground="{DynamicResource TextPrimary}"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                          <Button Content="{DynamicResource S.common.edit}" Style="{StaticResource MiniButton}"
                                  Command="{Binding DataContext.EditVhostCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" />
                          <Button Content="{DynamicResource S.common.delete}" Style="{StaticResource DangerButton}" Margin="6,0,0,0"
                                  Command="{Binding DataContext.DeleteVhostCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" />
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- SSL certificates -->
          <Grid Margin="2,16,0,6" Visibility="{Binding SupportsSsl, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{DynamicResource S.svc.view.sslCerts}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
              <Button Content="{DynamicResource S.svc.view.genSelfSigned}" Style="{StaticResource MiniButton}" Command="{Binding CreateCertCommand}" />
              <Button Content="{DynamicResource S.svc.view.import}" Style="{StaticResource MiniButton}" Margin="6,0,0,0" Command="{Binding ImportCertCommand}" />
              <Button Content="{DynamicResource S.svc.view.dir}" Style="{StaticResource MiniButton}" Margin="6,0,0,0" Command="{Binding OpenSslDirCommand}" />
            </StackPanel>
          </Grid>
          <Border Style="{StaticResource Card}" Padding="10,8" Visibility="{Binding SupportsSsl, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <TextBlock Text="{DynamicResource S.svc.view.noCerts}" FontSize="11.5" Foreground="{DynamicResource TextTertiary}" TextWrapping="Wrap"
                         Visibility="{Binding Certs.Count, Converter={StaticResource ZeroToVis}}" />
              <ItemsControl ItemsSource="{Binding Certs}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{DynamicResource PageBg}" CornerRadius="6" Padding="9,6" Margin="0,0,0,4">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" CornerRadius="5" Padding="6,1" Background="{DynamicResource AccentBg}" VerticalAlignment="Center">
                          <TextBlock Text="{Binding Kind}" FontSize="10" Foreground="{DynamicResource Accent}" />
                        </Border>
                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12.5" FontFamily="Consolas" Foreground="{DynamicResource TextPrimary}"
                                   VerticalAlignment="Center" Margin="8,0,8,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding Path}" />
                        <Button Grid.Column="2" Content="{DynamicResource S.common.delete}" Style="{StaticResource DangerButton}"
                                Command="{Binding DataContext.DeleteCertCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- logs -->
          <Grid Margin="2,16,0,6">
            <TextBlock Text="{DynamicResource S.nav.logs}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
              <Button Content="{DynamicResource S.svc.view.collect}" Style="{StaticResource MiniButton}" Command="{Binding CollectLogsCommand}" />
              <Button Content="{DynamicResource S.svc.view.dir}" Style="{StaticResource MiniButton}" Margin="6,0,0,0" Command="{Binding OpenLogDirCommand}" />
              <Button Content="↻" Style="{StaticResource MiniButton}" Margin="6,0,0,0" Command="{Binding RefreshLogsCommand}" />
            </StackPanel>
          </Grid>
          <Border Style="{StaticResource Card}" Padding="10,8">
            <StackPanel>
              <TextBlock Text="{DynamicResource S.svc.view.noLogs}" FontSize="11.5" Foreground="{DynamicResource TextTertiary}" TextWrapping="Wrap"
                         Visibility="{Binding Logs.Count, Converter={StaticResource ZeroToVis}}" />
              <ItemsControl ItemsSource="{Binding Logs}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{DynamicResource PageBg}" CornerRadius="6" Padding="9,6" Margin="0,0,0,4">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                          <TextBlock Text="{Binding Name}" FontSize="12.5" FontFamily="Consolas" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis" />
                          <TextBlock Text="{Binding SizeText}" FontSize="10.5" Foreground="{DynamicResource TextTertiary}" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="{DynamicResource S.svc.view.view}" Style="{StaticResource MiniButton}"
                                Command="{Binding DataContext.ShowLogCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" />
                        <Button Grid.Column="2" Content="{DynamicResource S.svc.view.clear}" Style="{StaticResource DangerButton}" Margin="6,0,0,0"
                                Command="{Binding DataContext.ClearLogCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>

      <!-- right: editor -->
      <Grid Grid.Column="1">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
          <Button DockPanel.Dock="Right" Content="{DynamicResource S.common.save}" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" />
          <TextBlock Text="{Binding CurrentPath}" FontSize="11.5" FontFamily="Consolas" Foreground="{DynamicResource TextSecondary}"
                     VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip="{Binding CurrentPath}" />
        </DockPanel>
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="2">
          <avalon:TextEditor x:Name="Editor" ShowLineNumbers="True" WordWrap="False"
                             FontFamily="Consolas" FontSize="12.5"
                             HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                             Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextPrimary}"
                             Padding="8" Margin="2" />
        </Border>
        <TextBlock Grid.Row="2" Margin="2,8,0,0" FontSize="11.5" Foreground="{DynamicResource TextTertiary}"
                   Text="{Binding Note}" TextWrapping="Wrap" />
      </Grid>
    </Grid>
  </Grid>
</UserControl>
