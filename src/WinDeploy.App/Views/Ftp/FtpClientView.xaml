<UserControl x:Class="WinDeploy.App.Views.Ftp.FtpClientView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:b="clr-namespace:WinDeploy.App.Behaviors">
  <UserControl.Resources>
    <Style x:Key="Lbl" TargetType="TextBlock">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource TextTertiary}" />
      <Setter Property="Margin" Value="0,0,0,3" />
    </Style>
  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- connection form -->
    <Border Grid.Row="0" Style="{StaticResource Card}" Padding="16,12">
      <StackPanel>
        <!-- saved credentials (site manager) -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
          <TextBlock Text="{DynamicResource S.ftp.client.profileLabel}" Style="{StaticResource Lbl}" VerticalAlignment="Center" Margin="0,0,8,0" />
          <ComboBox Width="240" Height="30" VerticalAlignment="Center" ItemsSource="{Binding Profiles}"
                    SelectedItem="{Binding SelectedProfile}" TextSearch.TextPath="Name">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Name}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <Button Content="{DynamicResource S.ftp.client.saveCurrent}" Style="{StaticResource MiniButton}" Margin="8,0,0,0" Command="{Binding SaveProfileCommand}" />
          <Button Content="{DynamicResource S.common.delete}" Style="{StaticResource DangerButton}" Margin="6,0,0,0" Command="{Binding DeleteProfileCommand}" />
          <TextBlock Text="{DynamicResource S.ftp.client.profileTip}" FontSize="11"
                     Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" Margin="10,0,0,0" />
        </StackPanel>
        <StackPanel Orientation="Horizontal">
          <StackPanel Margin="0,0,12,0">
            <TextBlock Text="{DynamicResource S.ftp.client.host}" Style="{StaticResource Lbl}" />
            <TextBox Width="220" Padding="8,5" b:InputFilter.Mode="host" Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" />
          </StackPanel>
          <StackPanel Margin="0,0,12,0">
            <TextBlock Text="{DynamicResource S.ftp.client.port}" Style="{StaticResource Lbl}" />
            <TextBox Width="70" Padding="8,5" b:InputFilter.Mode="digits" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />
          </StackPanel>
          <StackPanel Margin="0,0,12,0">
            <TextBlock Text="{DynamicResource S.ftp.client.userName}" Style="{StaticResource Lbl}" />
            <TextBox Width="140" Padding="8,5" Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" />
          </StackPanel>
          <StackPanel>
            <TextBlock Text="{DynamicResource S.ftp.client.password}" Style="{StaticResource Lbl}" />
            <PasswordBox x:Name="PwBox" Width="140" Padding="8,5"
                         Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource BorderStrong}" />
          </StackPanel>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
          <RadioButton Content="{DynamicResource S.ftp.client.plaintext}" GroupName="cliTls" IsChecked="{Binding IsTlsNone}" Margin="0,0,14,0" />
          <RadioButton Content="{DynamicResource S.ftp.client.tlsExplicit}" GroupName="cliTls" IsChecked="{Binding IsTlsExplicit}" Margin="0,0,14,0" />
          <RadioButton Content="{DynamicResource S.ftp.client.tlsImplicit}" GroupName="cliTls" IsChecked="{Binding IsTlsImplicit}" Margin="0,0,20,0" />
          <Button Content="{DynamicResource S.ftp.client.connect}" Style="{StaticResource OkButton}" Margin="0,0,8,0" Command="{Binding ConnectCommand}" />
          <Button Content="{DynamicResource S.ftp.client.disconnect}" Style="{StaticResource DangerButton}" Command="{Binding DisconnectCommand}" />
          <TextBlock Text="{Binding StatusText}" FontSize="12.5" FontWeight="SemiBold" Margin="16,0,0,0" VerticalAlignment="Center">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TextTertiary}" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Connected}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource OkFg}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- dual pane -->
    <Grid Grid.Row="1" Margin="0,12,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="12" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- local -->
      <Border Grid.Column="0" Style="{StaticResource Card}" Padding="2">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Text="{DynamicResource S.ftp.client.local}" FontWeight="SemiBold" FontSize="13" Margin="12,10,12,2" />
          <DockPanel Grid.Row="1" Margin="10,0,10,6">
            <Button DockPanel.Dock="Left" Content="{DynamicResource S.ftp.client.up}" Style="{StaticResource MiniButton}" Margin="0,0,6,0" Command="{Binding LocalUpCommand}" />
            <Button DockPanel.Dock="Left" Content="{DynamicResource S.ftp.client.pickDir}" Style="{StaticResource MiniButton}" Margin="0,0,6,0" Command="{Binding PickLocalCommand}" />
            <Button DockPanel.Dock="Right" Content="{DynamicResource S.ftp.client.upload}" Style="{StaticResource InfoButton}" Command="{Binding UploadCommand}"
                    ToolTip="{DynamicResource S.ftp.client.uploadTip}" />
            <TextBlock Text="{Binding LocalDir}" FontSize="11" FontFamily="Consolas" Foreground="{DynamicResource TextTertiary}"
                       VerticalAlignment="Center" Margin="6,0,8,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding LocalDir}" />
          </DockPanel>
          <DataGrid x:Name="LocalGrid" Grid.Row="2" ItemsSource="{Binding LocalEntries}" SelectedItem="{Binding SelectedLocal}"
                    AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" CanUserAddRows="False"
                    GridLinesVisibility="Horizontal" Background="Transparent" Margin="6,0,6,6"
                    MouseDoubleClick="LocalGrid_MouseDoubleClick" PreviewMouseRightButtonDown="Grid_RightSelect"
                    SelectionMode="Extended" SelectionChanged="LocalGrid_SelectionChanged">
            <DataGrid.ContextMenu>
              <ContextMenu Style="{StaticResource ThemedContextMenu}">
                <MenuItem Header="{DynamicResource S.ftp.client.open}" Style="{StaticResource ThemedMenuItem}"
                          Command="{Binding PlacementTarget.DataContext.OpenLocalItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                  <MenuItem.Icon><TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextSecondary}" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{DynamicResource S.ftp.client.uploadToRemote}" Style="{StaticResource ThemedMenuItem}"
                          Command="{Binding PlacementTarget.DataContext.UploadCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                  <MenuItem.Icon><TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource Accent}" /></MenuItem.Icon>
                </MenuItem>
                <Separator Style="{StaticResource ThemedSeparator}" />
                <MenuItem Header="{DynamicResource S.common.rename}" Style="{StaticResource ThemedMenuItem}"
                          Command="{Binding PlacementTarget.DataContext.RenameLocalCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                  <MenuItem.Icon><TextBlock Text="&#xE8AC;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextSecondary}" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{DynamicResource S.common.delete}" Style="{StaticResource ThemedMenuItem}"
                          Command="{Binding PlacementTarget.DataContext.DeleteLocalCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                  <MenuItem.Icon><TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource FailFg}" /></MenuItem.Icon>
                </MenuItem>
              </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
              <DataGridTemplateColumn Width="28">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="{DynamicResource S.ftp.col.name}" Binding="{Binding Name}" Width="*" />
              <DataGridTextColumn Header="{DynamicResource S.ftp.col.size}" Binding="{Binding SizeText}" Width="Auto" />
              <DataGridTextColumn Header="{DynamicResource S.ftp.col.modified}" Binding="{Binding ModifiedText}" Width="Auto" />
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </Border>

      <!-- remote -->
      <Border Grid.Column="2" Style="{StaticResource Card}" Padding="2">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Text="{DynamicResource S.ftp.client.remote}" FontWeight="SemiBold" FontSize="13" Margin="12,10,12,2" />
          <DockPanel Grid.Row="1" Margin="10,0,10,6">
            <Button DockPanel.Dock="Left" Content="{DynamicResource S.ftp.client.up}" Style="{StaticResource MiniButton}" Margin="0,0,6,0" Command="{Binding RemoteUpCommand}" />
            <Button DockPanel.Dock="Left" Content="↻" Style="{StaticResource MiniButton}" Margin="0,0,6,0" Command="{Binding RefreshRemoteCommand}" />
            <Button DockPanel.Dock="Left" Content="{DynamicResource S.ftp.client.mkdir}" Style="{StaticResource MiniButton}" Margin="0,0,6,0" Command="{Binding MkdirRemoteCommand}" />
            <Button DockPanel.Dock="Right" Content="{DynamicResource S.common.delete}" Style="{StaticResource DangerButton}" Command="{Binding DeleteRemoteCommand}" />
            <Button DockPanel.Dock="Right" Content="{DynamicResource S.common.rename}" Style="{StaticResource MiniButton}" Margin="0,0,6,0" Command="{Binding RenameRemoteCommand}" />
            <Button DockPanel.Dock="Right" Content="{DynamicResource S.ftp.client.download}" Style="{StaticResource InfoButton}" Margin="0,0,6,0" Command="{Binding DownloadCommand}"
                    ToolTip="{DynamicResource S.ftp.client.downloadTip}" />
            <TextBlock Text="{Binding RemoteDir}" FontSize="11" FontFamily="Consolas" Foreground="{DynamicResource TextTertiary}"
                       VerticalAlignment="Center" Margin="6,0,8,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding RemoteDir}" />
          </DockPanel>
          <Grid Grid.Row="2">
            <TextBlock Text="{DynamicResource S.ftp.client.noRemote}" FontSize="12.5" Foreground="{DynamicResource TextSecondary}"
                       Margin="14,10,0,0" VerticalAlignment="Top"
                       Visibility="{Binding NoRemote, Converter={StaticResource BoolToVis}}" />
            <DataGrid x:Name="RemoteGrid" ItemsSource="{Binding RemoteEntries}" SelectedItem="{Binding SelectedRemote}"
                      AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" CanUserAddRows="False"
                      GridLinesVisibility="Horizontal" Background="Transparent" Margin="6,0,6,6"
                      MouseDoubleClick="RemoteGrid_MouseDoubleClick" PreviewMouseRightButtonDown="Grid_RightSelect"
                      SelectionMode="Extended" SelectionChanged="RemoteGrid_SelectionChanged">
              <DataGrid.ContextMenu>
                <ContextMenu Style="{StaticResource ThemedContextMenu}">
                  <MenuItem Header="{DynamicResource S.ftp.client.open}" Style="{StaticResource ThemedMenuItem}"
                            Command="{Binding PlacementTarget.DataContext.OpenRemoteItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                    <MenuItem.Icon><TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextSecondary}" /></MenuItem.Icon>
                  </MenuItem>
                  <MenuItem Header="{DynamicResource S.ftp.client.downloadToLocal}" Style="{StaticResource ThemedMenuItem}"
                            Command="{Binding PlacementTarget.DataContext.DownloadCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                    <MenuItem.Icon><TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource Accent}" /></MenuItem.Icon>
                  </MenuItem>
                  <Separator Style="{StaticResource ThemedSeparator}" />
                  <MenuItem Header="{DynamicResource S.ftp.client.mkdir}" Style="{StaticResource ThemedMenuItem}"
                            Command="{Binding PlacementTarget.DataContext.MkdirRemoteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                    <MenuItem.Icon><TextBlock Text="&#xE8F4;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextSecondary}" /></MenuItem.Icon>
                  </MenuItem>
                  <MenuItem Header="{DynamicResource S.common.rename}" Style="{StaticResource ThemedMenuItem}"
                            Command="{Binding PlacementTarget.DataContext.RenameRemoteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                    <MenuItem.Icon><TextBlock Text="&#xE8AC;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextSecondary}" /></MenuItem.Icon>
                  </MenuItem>
                  <MenuItem Header="{DynamicResource S.common.delete}" Style="{StaticResource ThemedMenuItem}"
                            Command="{Binding PlacementTarget.DataContext.DeleteRemoteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                    <MenuItem.Icon><TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource FailFg}" /></MenuItem.Icon>
                  </MenuItem>
                </ContextMenu>
              </DataGrid.ContextMenu>
              <DataGrid.Columns>
                <DataGridTemplateColumn Width="28">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="{DynamicResource S.ftp.col.name}" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="{DynamicResource S.ftp.col.size}" Binding="{Binding SizeText}" Width="Auto" />
                <DataGridTextColumn Header="{DynamicResource S.ftp.col.modified}" Binding="{Binding ModifiedText}" Width="Auto" />
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <StackPanel Grid.Row="2" Margin="2,8,0,0">
      <!-- live transfer progress: speed + ETA -->
      <Border Style="{StaticResource Card}" Padding="12,8" Margin="0,0,0,6"
              Visibility="{Binding Transferring, Converter={StaticResource BoolToVis}}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" Margin="0,0,14,0" VerticalAlignment="Center">
            <TextBlock Text="{Binding TransferTitle}" FontSize="12.5" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis" />
            <ProgressBar Height="6" Minimum="0" Maximum="100" Value="{Binding ProgressValue, Mode=OneWay}" Margin="0,6,0,0"
                         Foreground="{DynamicResource Accent}" Background="{DynamicResource BorderSoft}" BorderThickness="0" />
          </StackPanel>
          <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
            <TextBlock FontSize="12.5" HorizontalAlignment="Right" Foreground="{DynamicResource Accent}">
              <Run Text="{DynamicResource S.ftp.client.speed}" /><Run Text="{Binding SpeedText, Mode=OneWay}" FontWeight="SemiBold" />
            </TextBlock>
            <TextBlock FontSize="12" HorizontalAlignment="Right" Margin="0,2,0,0" Foreground="{DynamicResource TextSecondary}">
              <Run Text="{DynamicResource S.ftp.client.eta}" /><Run Text="{Binding EtaText, Mode=OneWay}" />
            </TextBlock>
          </StackPanel>
        </Grid>
      </Border>
      <TextBlock Text="{Binding Note}" FontSize="12" Foreground="{DynamicResource TextTertiary}" TextWrapping="Wrap" />
    </StackPanel>

    <!-- log -->
    <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0" Margin="0,8,0,0" Height="110">
      <TextBox x:Name="LogBox" Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True"
               FontFamily="Consolas" FontSize="11" BorderThickness="0" Background="Transparent"
               VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap" Margin="8,6" />
    </Border>
  </Grid>
</UserControl>
