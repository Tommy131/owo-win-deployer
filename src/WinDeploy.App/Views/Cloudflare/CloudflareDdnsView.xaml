<UserControl x:Class="WinDeploy.App.Views.Cloudflare.CloudflareDdnsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="Cloudflare DDNS" FontSize="20" FontWeight="SemiBold" />
      <TextBlock Text="{DynamicResource S.cloud.intro}"
                 FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0" TextWrapping="Wrap" />
    </StackPanel>

    <!-- Margin right -24 / Padding right 24: scrollbar flush at the page's outer edge, content unchanged. -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,12,-24,0" Padding="0,0,24,0">
      <StackPanel>

        <!-- ① API 令牌 ──────────────────────────────────────────────────────────── -->
        <Border Style="{StaticResource Card}" Padding="16,13">
          <StackPanel>
            <TextBlock Text="{DynamicResource S.cloud.token.section}" FontSize="14" FontWeight="SemiBold" />
            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextTertiary}" Margin="0,4,0,0"
                       Text="{DynamicResource S.cloud.token.intro}" />
            <!-- Explicit auth-mode choice: prevents accidentally sending a token as a Global API Key (→ #6003). -->
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
              <RadioButton Content="{DynamicResource S.cloud.auth.token}" GroupName="CfAuth" IsChecked="{Binding UseApiToken}" VerticalAlignment="Center" FontSize="12.5" />
              <RadioButton Content="{DynamicResource S.cloud.auth.globalKey}" GroupName="CfAuth" IsChecked="{Binding UseGlobalKey}" Margin="18,0,0,0" VerticalAlignment="Center" FontSize="12.5" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
              <TextBlock Text="{Binding TokenLabel}" Width="92" FontSize="12.5" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
              <PasswordBox x:Name="TokenBox" Width="330" Padding="8,6" VerticalContentAlignment="Center"
                           Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextPrimary}"
                           BorderBrush="{DynamicResource BorderStrong}" />
              <Button Content="{DynamicResource S.cloud.token.save}" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"
                      Command="{Binding VerifyTokenCommand}" />
            </StackPanel>
            <!-- Help links on their own line (indented under the input) so the credential row never crowds. -->
            <StackPanel Orientation="Horizontal" Margin="92,8,0,0">
              <Button Content="{DynamicResource S.cloud.token.help.perms}" Style="{StaticResource MiniButton}" Command="{Binding ShowPermsCommand}" />
              <Button Content="{DynamicResource S.cloud.token.help.create}" Style="{StaticResource MiniButton}" Margin="8,0,0,0"
                      Command="{Binding OpenTokenHelpCommand}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center"
                        Visibility="{Binding ShowEmail, Converter={StaticResource BoolToVis}}">
              <TextBlock Text="{DynamicResource S.cloud.email.label}" Width="92" FontSize="12.5" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
              <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Width="280" Height="30" VerticalContentAlignment="Center" />
              <TextBlock Text="{DynamicResource S.cloud.email.hint}" FontSize="11" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" Margin="8,0,0,0" />
            </StackPanel>
            <TextBlock Text="{Binding TokenStatus}" FontSize="12.5" Margin="0,8,0,0" TextWrapping="Wrap">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding TokenOk}" Value="True">
                      <Setter Property="Foreground" Value="{DynamicResource OkFg}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </StackPanel>
        </Border>

        <!-- ② DDNS 监听 ─────────────────────────────────────────────────────────── -->
        <Border Style="{StaticResource Card}" Padding="16,13" Margin="0,12,0,0">
          <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="{DynamicResource S.cloud.monitor.section}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <TextBlock Text="{Binding StatusText}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource TextTertiary}" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding MonitorRunning}" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource OkFg}" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                </StackPanel>
                <TextBlock Text="{Binding CurrentIpText}" FontSize="12.5" FontFamily="Consolas" Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,0" TextWrapping="Wrap" />
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="{DynamicResource S.cloud.monitor.start}" Style="{StaticResource OkButton}" Command="{Binding StartMonitorCommand}" />
                <Button Content="{DynamicResource S.cloud.monitor.stop}" Style="{StaticResource DangerButton}" Margin="6,0,0,0" Command="{Binding StopMonitorCommand}" />
                <Button Content="{DynamicResource S.cloud.monitor.checkNow}" Style="{StaticResource InfoButton}" Margin="6,0,0,0" Command="{Binding RunOnceCommand}" />
              </StackPanel>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0" VerticalAlignment="Center">
              <TextBlock Text="{DynamicResource S.cloud.monitor.intervalLabel}" FontSize="12.5" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
              <TextBox Text="{Binding IntervalText, UpdateSourceTrigger=PropertyChanged}" Width="80" Height="28" VerticalContentAlignment="Center" />
              <CheckBox Content="{DynamicResource S.cloud.monitor.autoStart}" IsChecked="{Binding AutoStart}" Margin="18,0,0,0" VerticalAlignment="Center" FontSize="12.5" />
            </StackPanel>
            <TextBlock Text="{Binding LastResultText}" FontSize="12" Foreground="{DynamicResource TextTertiary}" Margin="0,8,0,0" TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <!-- ③ 域名与解析 ───────────────────────────────────────────────────────── -->
        <Border Style="{StaticResource Card}" Padding="16,13" Margin="0,12,0,0">
          <StackPanel>
            <TextBlock Text="{DynamicResource S.cloud.record.section}" FontSize="14" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
              <TextBlock Text="{DynamicResource S.cloud.zones.domainLabel}" FontSize="13" VerticalAlignment="Center" />
              <ComboBox Width="260" Height="30" Margin="6,0,0,0" VerticalAlignment="Center"
                        ItemsSource="{Binding Zones}" SelectedItem="{Binding SelectedZone}" />
              <Button Content="{DynamicResource S.cloud.records.refreshZones}" Style="{StaticResource MiniButton}" Margin="8,0,0,0" Command="{Binding RefreshZonesCommand}" />
              <Button Content="{DynamicResource S.cloud.records.refreshRecords}" Style="{StaticResource MiniButton}" Margin="6,0,0,0" Command="{Binding RefreshRecordsCommand}" />
              <Button Content="{DynamicResource S.cloud.records.newRecord}" Style="{StaticResource InfoButton}" Margin="6,0,0,0" Command="{Binding NewRecordCommand}" />
            </StackPanel>
            <TextBlock Text="{Binding Note}" FontSize="12" Foreground="{DynamicResource TextTertiary}" Margin="0,8,0,0" TextWrapping="Wrap" />

            <ItemsControl ItemsSource="{Binding Records}" Margin="0,10,0,0">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="{DynamicResource PageBg}" CornerRadius="8" Padding="12,9" Margin="0,0,0,7">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                          <Border CornerRadius="4" Padding="6,1" Background="{DynamicResource AccentBg}" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Type}" FontSize="10.5" Foreground="{DynamicResource Accent}" />
                          </Border>
                          <TextBlock Text="{Binding Name}" FontSize="13.5" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                          <Border CornerRadius="4" Padding="6,1" Margin="8,0,0,0" Background="{DynamicResource WarnBg}" VerticalAlignment="Center"
                                  Visibility="{Binding Proxied, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{DynamicResource S.cloud.record.proxied}" FontSize="10" Foreground="{DynamicResource WarnFg}" />
                          </Border>
                          <Border CornerRadius="4" Padding="6,1" Margin="6,0,0,0" Background="{DynamicResource OkBg}" VerticalAlignment="Center"
                                  Visibility="{Binding IsBound, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="DDNS" FontSize="10" Foreground="{DynamicResource OkFg}" />
                          </Border>
                        </StackPanel>
                        <TextBlock FontSize="12" FontFamily="Consolas" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0" TextWrapping="Wrap">
                          <Run Text="{Binding Content, Mode=OneWay}" /><Run Text="   · TTL " /><Run Text="{Binding TtlText, Mode=OneWay}" />
                        </TextBlock>
                      </StackPanel>
                      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="{DynamicResource S.cloud.record.setToCurrentIp}" Style="{StaticResource OkButton}"
                                Visibility="{Binding IsDdnsEligible, Converter={StaticResource BoolToVis}}"
                                Command="{Binding DataContext.UpdateToCurrentIpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}" />
                        <Button Content="{Binding BindLabel}" Style="{StaticResource MiniButton}" Margin="6,0,0,0"
                                Visibility="{Binding IsDdnsEligible, Converter={StaticResource BoolToVis}}"
                                Command="{Binding DataContext.ToggleBindCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}" />
                        <Button Content="{DynamicResource S.common.edit}" Style="{StaticResource MiniButton}" Margin="6,0,0,0"
                                Command="{Binding DataContext.EditRecordCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}" />
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- ④ 已绑定的 DDNS 记录 ─────────────────────────────────────────────────────
             Placed BELOW the records list on purpose: binding / unbinding only adds or removes a row here at
             the bottom, so the records list above (where the 「绑定 DDNS」 button is) never shifts. -->
        <Border Style="{StaticResource Card}" Padding="16,13" Margin="0,12,0,0">
          <StackPanel>
            <TextBlock Text="{DynamicResource S.cloud.section.bound}" FontSize="14" FontWeight="SemiBold" />
            <TextBlock Text="{DynamicResource S.cloud.section.boundDesc}"
                       FontSize="12" Foreground="{DynamicResource TextTertiary}" Margin="0,4,0,0" TextWrapping="Wrap" />
            <TextBlock Text="{DynamicResource S.cloud.section.boundEmpty}"
                       FontSize="12" Foreground="{DynamicResource TextTertiary}" Margin="0,8,0,0" TextWrapping="Wrap"
                       Visibility="{Binding NoBindings, Converter={StaticResource BoolToVis}}" />
            <ItemsControl ItemsSource="{Binding Bindings}" Margin="0,8,0,0"
                          Visibility="{Binding HasBindings, Converter={StaticResource BoolToVis}}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="{DynamicResource PageBg}" CornerRadius="6" Padding="10,7" Margin="0,0,0,5">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <CheckBox Grid.Column="0" IsChecked="{Binding Enabled}" VerticalAlignment="Center" Margin="0,0,10,0"
                                ToolTip="{DynamicResource S.cloud.section.pauseTooltip}" />
                      <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                          <Border CornerRadius="4" Padding="5,1" Background="{DynamicResource AccentBg}" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Type}" FontSize="10.5" Foreground="{DynamicResource Accent}" />
                          </Border>
                          <TextBlock Text="{Binding RecordName}" FontSize="13" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock FontSize="11.5" Foreground="{DynamicResource TextTertiary}" Margin="0,3,0,0">
                          <Run Text="{DynamicResource S.cloud.section.lastAppliedIp}" /><Run Text="{Binding LastIpText, Mode=OneWay}" /><Run Text="   " /><Run Text="{Binding LastUpdateText, Mode=OneWay}" />
                        </TextBlock>
                      </StackPanel>
                      <Button Grid.Column="2" Content="{DynamicResource S.common.remove}" Style="{StaticResource MiniButton}" VerticalAlignment="Center"
                              Command="{Binding DataContext.RemoveBindingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              CommandParameter="{Binding}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
