<UserControl x:Class="WinDeploy.App.Views.Terminal.TerminalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:v="clr-namespace:WinDeploy.App.Views.Terminal">
  <UserControl.Resources>
    <!-- Picker row: a color dot (quick locator) + the session's name / remark. Used both in the dropdown
         list and in the ComboBox's selection box. -->
    <DataTemplate x:Key="SessionItemTemplate">
      <StackPanel Orientation="Horizontal">
        <Image Source="{Binding ShellIcon}" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,7,0"
               RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" />
        <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,7,0" Fill="{Binding ColorBrush}" />
        <TextBlock Text="{Binding Title}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
      </StackPanel>
    </DataTemplate>
  </UserControl.Resources>

  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="{DynamicResource S.term.title}" FontSize="20" FontWeight="SemiBold" />
      <TextBlock Text="{DynamicResource S.term.subtitle}" FontSize="13"
                 Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0" TextWrapping="Wrap" />
    </StackPanel>

    <!-- Tab strip (left) + active-session actions (right) -->
    <Grid Grid.Row="1" Margin="0,12,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <StackPanel Grid.Column="0" Orientation="Horizontal">
        <ComboBox x:Name="SessionPicker" MinWidth="200" MaxWidth="300" Height="32" VerticalAlignment="Center"
                  ItemsSource="{Binding Sessions}" SelectedItem="{Binding ActiveSession, Mode=TwoWay}"
                  ItemTemplate="{StaticResource SessionItemTemplate}" ToolTip="{DynamicResource S.term.picker.tip}" />
        <Button x:Name="NewBtn" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"
                Click="OnNewSessionClick" ToolTip="{DynamicResource S.term.new.tip}" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center"
                       Margin="0,0,7,0" Foreground="{DynamicResource Accent}" />
            <TextBlock Text="{DynamicResource S.common.new}" VerticalAlignment="Center" Foreground="{DynamicResource Accent}" />
          </StackPanel>
        </Button>
        <Button Content="{DynamicResource S.term.session.edit}" Style="{StaticResource MiniButton}" Margin="6,0,0,0" VerticalAlignment="Center"
                Command="{Binding EditSessionCommand}" CommandParameter="{Binding ActiveSession}"
                ToolTip="{DynamicResource S.term.session.editTip}" />
        <Button Content="{DynamicResource S.term.session.close}" Style="{StaticResource MiniButton}" Margin="6,0,0,0" VerticalAlignment="Center"
                Command="{Binding CloseSessionCommand}" CommandParameter="{Binding ActiveSession}"
                ToolTip="{DynamicResource S.term.session.closeTip}" />
      </StackPanel>

      <StackPanel Grid.Column="1" Orientation="Horizontal" DataContext="{Binding ActiveSession}">
        <Button Content="{DynamicResource S.term.session.clear}" Style="{StaticResource MiniButton}" Command="{Binding ClearCommand}" Margin="8,0,0,0" />
        <Button Content="{DynamicResource S.term.session.restart}" Style="{StaticResource MiniButton}" Command="{Binding RestartCommand}" Margin="6,0,0,0"
                ToolTip="{DynamicResource S.term.session.restartTip}" />
      </StackPanel>
    </Grid>

    <TextBlock Grid.Row="2" Text="{Binding ActiveSession.Status}" FontSize="12" Margin="2,8,0,0"
               Foreground="{DynamicResource TextTertiary}" TextTrimming="CharacterEllipsis" />

    <Border x:Name="Host" Grid.Row="3" CornerRadius="10" Margin="0,8,0,0" ClipToBounds="True"
            Background="#060A06" BorderBrush="{DynamicResource BorderSoft}" BorderThickness="1">
      <Grid>
        <v:CodeRain x:Name="Rain" />
        <v:TerminalSurface x:Name="Surface" />
        <Rectangle x:Name="Scanlines" IsHitTestVisible="False">
          <Rectangle.Fill>
            <DrawingBrush TileMode="Tile" Viewport="0,0,3,3" ViewportUnits="Absolute" Opacity="0.32">
              <DrawingBrush.Drawing>
                <GeometryDrawing Brush="#000000">
                  <GeometryDrawing.Geometry>
                    <RectangleGeometry Rect="0,2,3,1" />
                  </GeometryDrawing.Geometry>
                </GeometryDrawing>
              </DrawingBrush.Drawing>
            </DrawingBrush>
          </Rectangle.Fill>
        </Rectangle>
        <TextBlock x:Name="EmptyHint" IsHitTestVisible="False" Visibility="Collapsed"
                   HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13"
                   Foreground="{DynamicResource TextTertiary}"
                   Text="{DynamicResource S.term.empty}" />
      </Grid>
    </Border>

    <TextBlock Grid.Row="4" FontSize="11.5" Foreground="{DynamicResource TextTertiary}" Margin="2,8,0,0" TextWrapping="Wrap"
               Text="{DynamicResource S.term.hint}" />
  </Grid>
</UserControl>
