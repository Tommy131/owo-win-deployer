<UserControl x:Class="WinDeploy.App.Views.Sys.MaintenanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="{DynamicResource S.maint.title}" FontSize="20" FontWeight="SemiBold" />
      <TextBlock Text="{DynamicResource S.maint.subtitle}"
                 FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0" TextWrapping="Wrap" />
    </StackPanel>

    <!-- Margin right -24 / Padding right 24: scrollbar flush at the page's outer edge, content unchanged. -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,14,-24,0" Padding="0,0,24,0">
      <StackPanel>

        <!-- ① Repair commands -->
        <TextBlock Text="{DynamicResource S.maint.repair.title}" FontSize="15" FontWeight="SemiBold" Margin="2,0,0,8" />
        <ItemsControl ItemsSource="{Binding Repairs}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Style="{StaticResource Card}" Padding="14,11" Margin="0,0,0,8">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                      <Border CornerRadius="6" Padding="6,1" Margin="8,0,0,0" Background="{DynamicResource WarnBg}" VerticalAlignment="Center"
                              Visibility="{Binding NeedsAdmin, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource S.maint.repair.adminBadge}" FontSize="10" Foreground="{DynamicResource WarnFg}" />
                      </Border>
                      <Border CornerRadius="6" Padding="6,1" Margin="5,0,0,0" Background="{DynamicResource FailBg}" VerticalAlignment="Center"
                              Visibility="{Binding Risky, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource S.maint.repair.riskyBadge}" FontSize="10" Foreground="{DynamicResource FailFg}" />
                      </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding Detail}" FontSize="11.5" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0" TextWrapping="Wrap" />
                  </StackPanel>
                  <Button Grid.Column="1" Content="{DynamicResource S.maint.repair.run}" Style="{StaticResource InfoButton}" VerticalAlignment="Center"
                          Command="{Binding DataContext.RunRepairCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ② Junk cleaner -->
        <TextBlock Text="{DynamicResource S.maint.junk.title}" FontSize="15" FontWeight="SemiBold" Margin="2,18,0,8" />
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
          <Button Content="{DynamicResource S.maint.scan}" Style="{StaticResource MiniButton}" Command="{Binding ScanJunkCommand}" />
          <Button Content="{DynamicResource S.maint.junk.cleanSelected}" Style="{StaticResource WarnButton}" Margin="8,0,0,0" Command="{Binding CleanJunkCommand}" />
          <TextBlock Text="{Binding JunkNote}" FontSize="12" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" Margin="14,0,0,0" />
        </StackPanel>
        <ItemsControl ItemsSource="{Binding Junk}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Style="{StaticResource Card}" Padding="12,9" Margin="0,0,0,6">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" />
                  <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="{Binding Name}" FontSize="13.5" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Detail}" FontSize="11" FontFamily="Consolas" Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0" />
                  </StackPanel>
                  <TextBlock Grid.Column="2" Text="{Binding SizeText}" FontSize="13" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ③ Event log -->
        <TextBlock Text="{DynamicResource S.maint.events.title}" FontSize="15" FontWeight="SemiBold" Margin="2,18,0,8" />
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
          <Button Content="{DynamicResource S.common.refresh}" Style="{StaticResource MiniButton}" Command="{Binding RefreshEventsCommand}" />
          <TextBlock Text="{Binding EventNote}" FontSize="12" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" Margin="14,0,0,0" />
        </StackPanel>
        <ItemsControl ItemsSource="{Binding Events}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Style="{StaticResource Card}" Padding="12,9" Margin="0,0,0,6">
                <StackPanel>
                  <StackPanel Orientation="Horizontal">
                    <Border CornerRadius="6" Padding="6,1" Background="{DynamicResource FailBg}" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Level}" FontSize="10" Foreground="{DynamicResource FailFg}" />
                    </Border>
                    <Border CornerRadius="6" Padding="6,1" Margin="5,0,0,0" Background="{DynamicResource WarnBg}" VerticalAlignment="Center"
                            Visibility="{Binding IsCrash, Converter={StaticResource BoolToVis}}">
                      <TextBlock Text="{DynamicResource S.maint.event.crashBadge}" FontSize="10" Foreground="{DynamicResource WarnFg}" />
                    </Border>
                    <TextBlock Text="{Binding Source}" FontSize="12" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" MaxWidth="280" />
                    <TextBlock Text="{Binding Id, StringFormat=ID {0}}" FontSize="11" Foreground="{DynamicResource TextTertiary}" Margin="8,0,0,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Time}" FontSize="11" Foreground="{DynamicResource TextTertiary}" Margin="8,0,0,0" VerticalAlignment="Center" />
                  </StackPanel>
                  <TextBlock Text="{Binding Message}" FontSize="11.5" Foreground="{DynamicResource TextSecondary}" Margin="0,5,0,0" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
