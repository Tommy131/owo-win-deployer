<UserControl x:Class="WinDeploy.App.Views.Sys.EnvVarsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="{DynamicResource S.env.title}" FontSize="20" FontWeight="SemiBold" />
      <TextBlock Text="{DynamicResource S.env.subtitle}" FontSize="13"
                 Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0" />
    </StackPanel>

    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
      <RadioButton Content="{DynamicResource S.env.scope.user}" IsChecked="{Binding IsUser}" GroupName="scope" VerticalAlignment="Center" />
      <RadioButton Content="{DynamicResource S.env.scope.machine}" IsChecked="{Binding IsMachine}" GroupName="scope" VerticalAlignment="Center" Margin="16,0,0,0" />
      <Button Content="{DynamicResource S.common.add}" Style="{StaticResource MiniButton}" Command="{Binding AddCommand}" Margin="24,0,0,0" />
      <Button Content="{DynamicResource S.env.remove}" Style="{StaticResource MiniButton}" Command="{Binding RemoveCommand}" Margin="8,0,0,0" />
      <Button Content="{DynamicResource S.env.reload}" Style="{StaticResource MiniButton}" Command="{Binding ReloadCommand}" Margin="8,0,0,0" />
      <Button Content="{DynamicResource S.common.save}" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" Margin="8,0,0,0" />
    </StackPanel>

    <Border Grid.Row="2" Style="{StaticResource Card}" Padding="2" Margin="0,12,0,0">
      <DataGrid ItemsSource="{Binding Rows}" SelectedItem="{Binding SelectedRow}"
                AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                HeadersVisibility="Column" GridLinesVisibility="Horizontal" Background="Transparent"
                BorderThickness="0" RowBackground="Transparent" AlternatingRowBackground="Transparent"
                Foreground="{DynamicResource TextPrimary}">
        <DataGrid.Columns>
          <DataGridTextColumn Header="{DynamicResource S.env.col.name}" Binding="{Binding Name}" Width="240" />
          <DataGridTextColumn Header="{DynamicResource S.env.col.value}" Binding="{Binding Value}" Width="*" />
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <TextBlock Grid.Row="3" Text="{Binding Note}" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="2,10,0,0" />
  </Grid>
</UserControl>
