<UserControl x:Class="WinDeploy.App.Views.Sys.PowerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="{DynamicResource S.power.title}" FontSize="20" FontWeight="SemiBold" />
      <TextBlock Text="{DynamicResource S.power.subtitle}"
                 FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0" TextWrapping="Wrap" />
    </StackPanel>

    <!-- Margin right -24 / Padding right 24: scrollbar flush at the page's outer edge, content unchanged. -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,14,-24,0" Padding="0,0,24,0">
      <StackPanel>

        <!-- Active plan + refresh -->
        <Border Style="{StaticResource Card}" Padding="16,13" Margin="0,0,0,16">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="26"
                       Foreground="{DynamicResource Accent}" VerticalAlignment="Center" Margin="0,0,14,0" />
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
              <TextBlock Text="{DynamicResource S.power.active.label}" FontSize="12" Foreground="{DynamicResource TextSecondary}" />
              <TextBlock Text="{Binding ActivePlanName}" FontSize="18" FontWeight="SemiBold" Margin="0,2,0,0" />
              <TextBlock Text="{Binding Note}" FontSize="12" Foreground="{DynamicResource OkFg}" Margin="0,3,0,0"
                         TextWrapping="Wrap" Visibility="{Binding HasNote, Converter={StaticResource BoolToVis}}" />
            </StackPanel>
            <Button Grid.Column="2" Content="{DynamicResource S.common.refresh}" Style="{StaticResource MiniButton}"
                    VerticalAlignment="Center" Command="{Binding RefreshCommand}" />
          </Grid>
        </Border>

        <!-- Quick-switch presets -->
        <TextBlock Text="{DynamicResource S.power.presetsTitle}" FontSize="15" FontWeight="SemiBold" Margin="2,0,0,10" />
        <ItemsControl ItemsSource="{Binding Presets}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border x:Name="Card" Width="256" Padding="16" Margin="0,0,12,12">
                <StackPanel>
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Glyph}" FontFamily="Segoe MDL2 Assets" FontSize="22"
                               Foreground="{DynamicResource Accent}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" />
                    <Border CornerRadius="6" Padding="6,1" Margin="8,0,0,0" Background="{DynamicResource AccentBg}" VerticalAlignment="Center"
                            Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}">
                      <TextBlock Text="{DynamicResource S.power.activeBadge}" FontSize="10" Foreground="{DynamicResource Accent}" />
                    </Border>
                  </StackPanel>
                  <TextBlock Text="{Binding Detail}" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                             TextWrapping="Wrap" Margin="0,9,0,12" MinHeight="56" VerticalAlignment="Top" />
                  <Button Content="{Binding ActionLabel}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"
                          IsEnabled="{Binding CanApply}"
                          Command="{Binding DataContext.ApplyPresetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}" />
                </StackPanel>
                <Border.Style>
                  <Style TargetType="Border" BasedOn="{StaticResource Card}">
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsActive}" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- All registered plans -->
        <TextBlock Text="{DynamicResource S.power.allTitle}" FontSize="15" FontWeight="SemiBold" Margin="2,12,0,10" />
        <ItemsControl ItemsSource="{Binding Plans}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Style="{StaticResource Card}" Padding="12,9" Margin="0,0,0,6">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="{Binding Name}" FontSize="13.5" FontWeight="SemiBold" VerticalAlignment="Center" />
                      <Border CornerRadius="6" Padding="6,1" Margin="8,0,0,0" Background="{DynamicResource AccentBg}" VerticalAlignment="Center"
                              Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource S.power.activeBadge}" FontSize="10" Foreground="{DynamicResource Accent}" />
                      </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding ShortGuid}" FontSize="11" FontFamily="Consolas"
                               Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0" />
                  </StackPanel>
                  <Button Grid.Column="1" Content="{Binding ActionLabel}" Style="{StaticResource InfoButton}" VerticalAlignment="Center"
                          IsEnabled="{Binding CanApply}"
                          Command="{Binding DataContext.ApplyPlanCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
