<UserControl x:Class="WinDeploy.App.Views.Sys.ProcessManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="{DynamicResource S.proc.title}" FontSize="20" FontWeight="SemiBold" />
      <TextBlock Text="{DynamicResource S.proc.subtitle}" FontSize="13"
                 Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0" TextWrapping="Wrap" />
    </StackPanel>

    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
      <Button Content="{DynamicResource S.proc.refresh}" Style="{StaticResource MiniButton}" Command="{Binding RefreshCommand}"
              ToolTip="{DynamicResource S.proc.refresh.tip}" />
      <Button Content="{Binding ToggleAllLabel}" Style="{StaticResource InfoButton}" Command="{Binding ToggleAllCommand}" Margin="8,0,0,0"
              ToolTip="{DynamicResource S.proc.toggle.tip}" />
      <Button Content="{Binding ExpandAllLabel}" Style="{StaticResource MiniButton}" Command="{Binding ExpandCollapseAllCommand}" Margin="8,0,0,0"
              ToolTip="{DynamicResource S.proc.expandAll.tip}" />
      <Button Content="{DynamicResource S.proc.openTaskMgr}" Style="{StaticResource MiniButton}" Command="{Binding OpenTaskManagerCommand}" Margin="8,0,0,0"
              ToolTip="{DynamicResource S.proc.openTaskMgr.tip}" />
      <TextBlock Text="{Binding Summary}" FontSize="12" Foreground="{DynamicResource TextTertiary}"
                 VerticalAlignment="Center" Margin="16,0,0,0" />
    </StackPanel>

    <!-- Margin right -24 / Padding right 24: scrollbar flush at the page's outer edge, content unchanged. -->
    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,12,-24,0" Padding="0,0,24,0">
      <ItemsControl ItemsSource="{Binding Groups}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
           <StackPanel>
            <!-- Task-Manager-style section divider (用户进程 / 系统进程), shown on the first group of each section -->
            <TextBlock Text="{Binding SectionLabel}" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextTertiary}" Margin="2,6,0,6"
                       Visibility="{Binding ShowSectionHeader, Converter={StaticResource BoolToVis}}" />
            <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
              <StackPanel>
                <!-- group header -->
                <Grid>
                  <!-- 点击整个标题（图标 / 名称）展开 / 折叠；右键可对主进程结束 / 重启 / 打开位置 / 属性 -->
                  <Border Background="Transparent" Cursor="Hand" HorizontalAlignment="Left" ToolTip="{DynamicResource S.proc.headerTip}"
                          Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <Border.InputBindings>
                      <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleCommand}" />
                    </Border.InputBindings>
                    <Border.ContextMenu>
                      <ContextMenu Style="{StaticResource ThemedContextMenu}">
                        <MenuItem Header="{Binding ExpandMenuLabel}" Style="{StaticResource ThemedMenuItem}"
                                  Command="{Binding ToggleCommand}">
                          <MenuItem.Icon><TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextSecondary}" /></MenuItem.Icon>
                        </MenuItem>
                        <Separator Style="{StaticResource ThemedSeparator}" />
                        <MenuItem Header="{DynamicResource S.proc.menu.restart}" Style="{StaticResource ThemedMenuItem}"
                                  Visibility="{Binding IsCatalog, Converter={StaticResource BoolToVis}}"
                                  Command="{Binding PlacementTarget.Tag.RestartCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                          <MenuItem.Icon><TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource Accent}" /></MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{DynamicResource S.proc.menu.endAll}" Style="{StaticResource ThemedMenuItem}"
                                  Command="{Binding PlacementTarget.Tag.EndAllCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                          <MenuItem.Icon><TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource FailFg}" /></MenuItem.Icon>
                        </MenuItem>
                        <Separator Style="{StaticResource ThemedSeparator}" />
                        <MenuItem Header="{DynamicResource S.proc.menu.openLocation}" Style="{StaticResource ThemedMenuItem}"
                                  Command="{Binding PlacementTarget.Tag.OpenGroupFileLocationCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                          <MenuItem.Icon><TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextSecondary}" /></MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{DynamicResource S.proc.menu.properties}" Style="{StaticResource ThemedMenuItem}"
                                  Command="{Binding PlacementTarget.Tag.ShowGroupPropertiesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                          <MenuItem.Icon><TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextSecondary}" /></MenuItem.Icon>
                        </MenuItem>
                      </ContextMenu>
                    </Border.ContextMenu>
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="{Binding ExpandGlyph}" FontSize="10" Width="18" TextAlignment="Center"
                                 Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                      <Grid Width="26" Height="26" Margin="2,0,0,0">
                        <Border CornerRadius="6" Background="{DynamicResource PageBg}"
                                Visibility="{Binding ShowLetter, Converter={StaticResource BoolToVis}}">
                          <TextBlock Text="{Binding Badge}" FontSize="13" FontWeight="SemiBold"
                                     Foreground="{DynamicResource TextSecondary}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Image Source="{Binding IconImage}" Stretch="Uniform" Margin="2"
                               Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                      </Grid>
                      <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0" />
                      <TextBlock Text="{Binding CountText}" FontSize="12" Foreground="{DynamicResource TextTertiary}"
                                 Margin="10,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                  </Border>
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{DynamicResource S.proc.restart}" Style="{StaticResource InfoButton}"
                            Visibility="{Binding IsCatalog, Converter={StaticResource BoolToVis}}"
                            Command="{Binding DataContext.RestartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}" />
                    <Button Content="{DynamicResource S.proc.endAll}" Style="{StaticResource DangerButton}" Margin="8,0,0,0"
                            Command="{Binding DataContext.EndAllCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}" />
                  </StackPanel>
                </Grid>

                <!-- process rows (collapsible) -->
                <StackPanel Margin="30,8,0,0" Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                  <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="86" />
                      <ColumnDefinition Width="74" />
                      <ColumnDefinition Width="92" />
                      <ColumnDefinition Width="64" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource S.proc.col.proc}" FontSize="11" Foreground="{DynamicResource TextTertiary}" />
                    <TextBlock Grid.Column="1" Text="PID" FontSize="11" Foreground="{DynamicResource TextTertiary}" />
                    <TextBlock Grid.Column="2" Text="CPU" FontSize="11" Foreground="{DynamicResource TextTertiary}" />
                    <TextBlock Grid.Column="3" Text="{DynamicResource S.proc.col.mem}" FontSize="11" Foreground="{DynamicResource TextTertiary}" />
                  </Grid>
                  <ItemsControl ItemsSource="{Binding Processes}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <!-- Tag carries the page VM so the (popup) context menu can reach its commands.
                             Background must be non-null so the whole row is a right-click hit target. -->
                        <Grid Margin="0,3" Background="Transparent"
                              Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="86" />
                            <ColumnDefinition Width="74" />
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="64" />
                          </Grid.ColumnDefinitions>
                          <Grid.ContextMenu>
                            <ContextMenu Style="{StaticResource ThemedContextMenu}">
                              <MenuItem Header="{DynamicResource S.proc.menu.endTask}" Style="{StaticResource ThemedMenuItem}"
                                        Command="{Binding PlacementTarget.Tag.EndProcessCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                        CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                <MenuItem.Icon><TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource FailFg}" /></MenuItem.Icon>
                              </MenuItem>
                              <MenuItem Header="{DynamicResource S.proc.menu.openLocation}" Style="{StaticResource ThemedMenuItem}"
                                        Command="{Binding PlacementTarget.Tag.OpenFileLocationCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                        CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                <MenuItem.Icon><TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextSecondary}" /></MenuItem.Icon>
                              </MenuItem>
                              <MenuItem Header="{DynamicResource S.proc.menu.properties}" Style="{StaticResource ThemedMenuItem}"
                                        Command="{Binding PlacementTarget.Tag.ShowPropertiesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                        CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                <MenuItem.Icon><TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextSecondary}" /></MenuItem.Icon>
                              </MenuItem>
                            </ContextMenu>
                          </Grid.ContextMenu>
                          <TextBlock Grid.Column="0" Text="{Binding Name}" FontFamily="Consolas" FontSize="12.5" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="1" Text="{Binding Pid}" FontSize="12" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="2" Text="{Binding CpuText}" FontSize="12" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="3" Text="{Binding MemText}" FontSize="12" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                          <Button Grid.Column="4" Content="{DynamicResource S.proc.row.endBtn}" Style="{StaticResource DangerButton}"
                                  Command="{Binding DataContext.EndProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  CommandParameter="{Binding}" />
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </StackPanel>
            </Border>
           </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
