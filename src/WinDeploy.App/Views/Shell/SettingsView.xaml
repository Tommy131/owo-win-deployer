<UserControl x:Class="WinDeploy.App.Views.Shell.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:b="clr-namespace:WinDeploy.App.Behaviors">
  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="{DynamicResource S.settings.title}" FontSize="20" FontWeight="SemiBold" />
      <TextBlock Text="{DynamicResource S.settings.subtitle}" FontSize="13"
                 Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0" />
    </StackPanel>

    <!-- Margin right -24 / Padding right 24: scrollbar flush at the page's outer edge, content unchanged. -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,12,-24,0" Padding="0,0,24,0">
      <StackPanel>

        <Border Style="{StaticResource Card}" Padding="16">
          <StackPanel>
            <TextBlock Text="{DynamicResource S.settings.appearance.title}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10" />
            <StackPanel Orientation="Horizontal">
              <RadioButton Content="{DynamicResource S.settings.theme.system}" IsChecked="{Binding IsThemeSystem}" GroupName="theme" />
              <RadioButton Content="{DynamicResource S.settings.theme.light}" IsChecked="{Binding IsThemeLight}" GroupName="theme" Margin="20,0,0,0" />
              <RadioButton Content="{DynamicResource S.settings.theme.dark}" IsChecked="{Binding IsThemeDark}" GroupName="theme" Margin="20,0,0,0" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource Card}" Padding="16" Margin="0,12,0,0">
          <StackPanel>
            <TextBlock Text="{DynamicResource S.settings.lang.title}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="{DynamicResource S.settings.lang.desc}" FontSize="12"
                       Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10" />
            <StackPanel Orientation="Horizontal">
              <RadioButton Content="{DynamicResource S.settings.lang.zh}" IsChecked="{Binding IsLangZh}" GroupName="lang" />
              <RadioButton Content="{DynamicResource S.settings.lang.en}" IsChecked="{Binding IsLangEn}" GroupName="lang" Margin="20,0,0,0" />
              <RadioButton Content="{DynamicResource S.settings.lang.de}" IsChecked="{Binding IsLangDe}" GroupName="lang" Margin="20,0,0,0" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource Card}" Padding="16" Margin="0,12,0,0">
          <StackPanel>
            <TextBlock Text="{DynamicResource S.settings.termfx.title}" FontSize="14" FontWeight="SemiBold" />
            <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,4,0,10"
                       Text="{DynamicResource S.settings.termfx.desc}" />
            <CheckBox Content="{DynamicResource S.settings.termfx.hacker}" IsChecked="{Binding TermHacker}" FontSize="13" Margin="0,2,0,0" />
            <CheckBox Content="{DynamicResource S.settings.termfx.crt}" IsChecked="{Binding TermCrt}" FontSize="13" Margin="0,8,0,0" />
            <CheckBox Content="{DynamicResource S.settings.termfx.coderain}" IsChecked="{Binding TermCodeRain}" FontSize="13" Margin="0,8,0,0" />

            <Grid Margin="0,12,0,0" IsEnabled="{Binding CodeRainEnabled}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="56" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="{DynamicResource S.settings.termfx.opacity}" FontSize="12.5" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
              <Slider Grid.Column="1" Minimum="0.05" Maximum="1.0" Value="{Binding TermCodeOpacity}" VerticalAlignment="Center" Margin="6,0" />
              <TextBlock Grid.Column="2" Text="{Binding TermCodeOpacityText}" FontSize="12" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" HorizontalAlignment="Right" />
            </Grid>
            <TextBlock FontSize="11" Foreground="{DynamicResource TextTertiary}" TextWrapping="Wrap" Margin="0,4,0,0"
                       Text="{DynamicResource S.settings.termfx.opacityHint}" />

            <Grid Margin="0,10,0,0" IsEnabled="{Binding CodeRainEnabled}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="56" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="{DynamicResource S.settings.termfx.speed}" FontSize="12.5" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
              <Slider Grid.Column="1" Minimum="0.2" Maximum="4.0" Value="{Binding TermCodeSpeed}" VerticalAlignment="Center" Margin="6,0" />
              <TextBlock Grid.Column="2" Text="{Binding TermCodeSpeedText}" FontSize="12" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" HorizontalAlignment="Right" />
            </Grid>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource Card}" Padding="16" Margin="0,12,0,0">
          <StackPanel>
            <TextBlock Text="{DynamicResource S.settings.icons.title}" FontSize="14" FontWeight="SemiBold" />
            <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,4,0,10"
                       Text="{DynamicResource S.settings.icons.desc}" />
            <StackPanel Orientation="Horizontal">
              <Button Content="{DynamicResource S.settings.icons.refresh}" Style="{StaticResource InfoButton}" Command="{Binding RefreshIconsCommand}" />
              <TextBlock Text="{Binding IconNote}" FontSize="12" Foreground="{DynamicResource TextTertiary}"
                         VerticalAlignment="Center" Margin="12,0,0,0" TextTrimming="CharacterEllipsis" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource Card}" Padding="16" Margin="0,12,0,0">
          <StackPanel>
            <TextBlock Text="{DynamicResource S.settings.dev.title}" FontSize="14" FontWeight="SemiBold" />
            <CheckBox Content="{DynamicResource S.settings.dev.toggle}" IsChecked="{Binding DeveloperMode}"
                      FontSize="13" Margin="0,10,0,0" />
            <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,6,0,0"
                       Text="{DynamicResource S.settings.dev.desc}" />
          </StackPanel>
        </Border>

        <Border Style="{StaticResource Card}" Padding="16" Margin="0,12,0,0">
          <StackPanel>
            <TextBlock Text="{DynamicResource S.settings.close.title}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10" />
            <StackPanel Orientation="Horizontal">
              <RadioButton Content="{DynamicResource S.settings.close.ask}" IsChecked="{Binding IsCloseAsk}" GroupName="close" />
              <RadioButton Content="{DynamicResource S.settings.close.tray}" IsChecked="{Binding IsCloseTray}" GroupName="close" Margin="20,0,0,0" />
              <RadioButton Content="{DynamicResource S.settings.close.exit}" IsChecked="{Binding IsCloseExit}" GroupName="close" Margin="20,0,0,0" />
            </StackPanel>
            <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,8,0,0"
                       Text="{DynamicResource S.settings.close.desc}" />
          </StackPanel>
        </Border>

        <Border Style="{StaticResource Card}" Padding="16" Margin="0,12,0,0">
          <StackPanel>
            <TextBlock Text="{DynamicResource S.settings.autostart.title}" FontSize="14" FontWeight="SemiBold" />
            <CheckBox Content="{DynamicResource S.settings.autostart.boot}" IsChecked="{Binding RunAtStartup}" FontSize="13" Margin="0,10,0,0" />
            <TextBlock Text="{DynamicResource S.settings.autostart.bootDesc}" FontSize="12"
                       Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,4,0,0" />
            <CheckBox Content="{DynamicResource S.settings.autostart.tray}" IsChecked="{Binding AlwaysShowTray}" FontSize="13" Margin="0,12,0,0" />
            <TextBlock Text="{DynamicResource S.settings.autostart.trayDesc}" FontSize="12"
                       Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,4,0,0" />
          </StackPanel>
        </Border>

        <!-- 硬件温度监控 -->
        <Border Style="{StaticResource Card}" Padding="16" Margin="0,12,0,0">
          <StackPanel>
            <TextBlock Text="{DynamicResource S.settings.tempmon.title}" FontSize="14" FontWeight="SemiBold" />
            <TextBlock Text="{DynamicResource S.settings.tempmon.desc}" FontSize="12"
                       Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,4,0,0" />
            <CheckBox Content="{DynamicResource S.settings.tempmon.enable}" IsChecked="{Binding TempMonitorEnabled}" FontSize="13" Margin="0,10,0,0" />

            <StackPanel IsEnabled="{Binding TempMonitorEnabled}" Margin="0,6,0,0">
              <CheckBox Content="{DynamicResource S.settings.tempmon.tts}" IsChecked="{Binding TempTts}" FontSize="13" Margin="0,4,0,0" />

              <!-- 每个硬件：启用开关 + 阈值（°C） -->
              <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0" Content="{DynamicResource S.settings.tempmon.cpu}" IsChecked="{Binding TempCpu}" FontSize="13" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" Text="{Binding CpuTempThreshold}" b:InputFilter.Mode="digits" Width="56" Height="30"
                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Padding="4,0" />
                <TextBlock Grid.Column="2" Text="{DynamicResource S.settings.tempmon.unit}" FontSize="12.5" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="6,0,0,0" />
              </Grid>
              <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0" Content="{DynamicResource S.settings.tempmon.gpu}" IsChecked="{Binding TempGpu}" FontSize="13" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" Text="{Binding GpuTempThreshold}" b:InputFilter.Mode="digits" Width="56" Height="30"
                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Padding="4,0" />
                <TextBlock Grid.Column="2" Text="{DynamicResource S.settings.tempmon.unit}" FontSize="12.5" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="6,0,0,0" />
              </Grid>
              <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0" Content="{DynamicResource S.settings.tempmon.disk}" IsChecked="{Binding TempDisk}" FontSize="13" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" Text="{Binding DiskTempThreshold}" b:InputFilter.Mode="digits" Width="56" Height="30"
                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Padding="4,0" />
                <TextBlock Grid.Column="2" Text="{DynamicResource S.settings.tempmon.unit}" FontSize="12.5" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="6,0,0,0" />
              </Grid>

              <!-- 提醒频率：温度持续过高时的重复提醒间隔，集中统一管理（非单设备） -->
              <Grid Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource S.settings.tempmon.freq}" FontSize="13"
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1" Width="150" Height="32" SelectedIndex="{Binding ReminderIndex}">
                  <ComboBoxItem Content="{DynamicResource S.tempmon.freq.30s}" />
                  <ComboBoxItem Content="{DynamicResource S.tempmon.freq.1m}" />
                  <ComboBoxItem Content="{DynamicResource S.tempmon.freq.2m}" />
                  <ComboBoxItem Content="{DynamicResource S.tempmon.freq.5m}" />
                  <ComboBoxItem Content="{DynamicResource S.tempmon.freq.10m}" />
                </ComboBox>
              </Grid>

              <Button Content="{DynamicResource S.settings.tempmon.test}" Style="{StaticResource MiniButton}"
                      HorizontalAlignment="Left" Margin="0,12,0,0" Command="{Binding TestTtsCommand}" />
            </StackPanel>

            <TextBlock Text="{DynamicResource S.settings.tempmon.note}" FontSize="11.5"
                       Foreground="{DynamicResource TextTertiary}" TextWrapping="Wrap" Margin="0,12,0,0" />
          </StackPanel>
        </Border>

        <Border Style="{StaticResource Card}" Padding="16" Margin="0,12,0,0">
          <StackPanel>
            <TextBlock Text="{DynamicResource S.settings.paths.title}" FontSize="14" FontWeight="SemiBold" />
            <TextBlock Text="{DynamicResource S.settings.paths.desc}" FontSize="12"
                       Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,10" />
            <TextBlock Text="{DynamicResource S.settings.paths.devRoot}" FontSize="12" Foreground="{DynamicResource TextSecondary}" />
            <TextBox Text="{Binding DevRoot, UpdateSourceTrigger=PropertyChanged}" Height="34" VerticalContentAlignment="Center" Padding="8,0" Margin="0,3,0,10" />
            <TextBlock Text="{DynamicResource S.settings.paths.toolsDir}" FontSize="12" Foreground="{DynamicResource TextSecondary}" />
            <TextBox Text="{Binding ToolsDir, UpdateSourceTrigger=PropertyChanged}" Height="34" VerticalContentAlignment="Center" Padding="8,0" Margin="0,3,0,10" />
            <TextBlock Text="{DynamicResource S.settings.paths.downloadDir}" FontSize="12" Foreground="{DynamicResource TextSecondary}" />
            <TextBox Text="{Binding DownloadDir, UpdateSourceTrigger=PropertyChanged}" Height="34" VerticalContentAlignment="Center" Padding="8,0" Margin="0,3,0,0" />
          </StackPanel>
        </Border>

        <Border Style="{StaticResource Card}" Padding="16" Margin="0,12,0,0">
          <StackPanel>
            <TextBlock Text="{DynamicResource S.settings.repo.title}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10" />
            <TextBlock Text="{DynamicResource S.settings.repo.url}" FontSize="12" Foreground="{DynamicResource TextSecondary}" />
            <TextBox Text="{Binding RepoUrl, UpdateSourceTrigger=PropertyChanged}" Height="34" VerticalContentAlignment="Center" Padding="8,0" Margin="0,3,0,10" />
            <TextBlock Text="{DynamicResource S.settings.repo.mirror}" FontSize="12" Foreground="{DynamicResource TextSecondary}" />
            <TextBox Text="{Binding Mirror, UpdateSourceTrigger=PropertyChanged}" Height="34" VerticalContentAlignment="Center" Padding="8,0" Margin="0,3,0,0" />
          </StackPanel>
        </Border>

        <!-- 下载代理 -->
        <Border Style="{StaticResource Card}" Padding="16" Margin="0,12,0,0">
          <StackPanel>
            <TextBlock Text="{DynamicResource S.settings.proxy.title}" FontSize="14" FontWeight="SemiBold" />
            <TextBlock Text="{DynamicResource S.settings.proxy.desc}" FontSize="12"
                       Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,4,0,10" />
            <CheckBox Content="{DynamicResource S.settings.proxy.enable}" IsChecked="{Binding ProxyEnabled}" FontSize="13" />
            <StackPanel IsEnabled="{Binding ProxyEnabled}" Margin="0,8,0,0">
              <TextBlock Text="{DynamicResource S.settings.proxy.url}" FontSize="12" Foreground="{DynamicResource TextSecondary}" />
              <TextBox Text="{Binding ProxyUrl, UpdateSourceTrigger=PropertyChanged}" b:InputFilter.Mode="proxy"
                       Height="34" VerticalContentAlignment="Center" Padding="8,0" Margin="0,3,0,0" FontFamily="Consolas" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
              <Button Content="{DynamicResource S.settings.proxy.save}" Style="{StaticResource PrimaryButton}"
                      Command="{Binding SaveProxyCommand}" />
              <TextBlock Text="{Binding ProxyNote}" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                         VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap" />
            </StackPanel>
            <TextBlock Text="{DynamicResource S.settings.proxy.note}" FontSize="11.5"
                       Foreground="{DynamicResource TextTertiary}" TextWrapping="Wrap" Margin="0,10,0,0" />
          </StackPanel>
        </Border>

        <Border Style="{StaticResource Card}" Padding="16" Margin="0,12,0,0">
          <StackPanel>
            <TextBlock Text="{DynamicResource S.settings.redact.title}" FontSize="14" FontWeight="SemiBold" />
            <TextBlock Text="{DynamicResource S.settings.redact.desc}" FontSize="12"
                       Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,2,0,10" />
            <TextBox Text="{Binding RedactKeywords, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap"
                     Height="68" VerticalContentAlignment="Top" Padding="8,6" />
          </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
          <Button Content="{DynamicResource S.settings.save}" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" />
          <Button Content="{DynamicResource S.settings.reset.button}" Style="{StaticResource DangerButton}" Margin="10,0,0,0"
                  Command="{Binding ResetCommand}" ToolTip="{DynamicResource S.settings.reset.warn1.title}" />
          <TextBlock Text="{Binding Note}" Foreground="{DynamicResource OkFg}" VerticalAlignment="Center" Margin="14,0,0,0" />
        </StackPanel>

        <!-- 关于 + 检查更新 -->
        <Border Style="{StaticResource Card}" Padding="16" Margin="0,12,0,0">
          <StackPanel>
            <TextBlock Text="{DynamicResource S.settings.about.title}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBlock Text="{Binding AppTitle, Mode=OneWay}" FontSize="13" FontWeight="SemiBold" />
            <TextBlock Text="{Binding AppCopyright, Mode=OneWay}" FontSize="12" Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0" />
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
              <Button Content="{DynamicResource S.settings.about.checkUpdate}" Style="{StaticResource PrimaryButton}" Command="{Binding CheckUpdateCommand}"
                      ToolTip="{DynamicResource S.settings.about.checkUpdateTip}" />
              <Button Content="{DynamicResource S.settings.about.openDataDir}" Style="{StaticResource MiniButton}" Command="{Binding OpenFolderCommand}" Margin="8,0,0,0"
                      ToolTip="{DynamicResource S.settings.about.openDataDirTip}" />
              <TextBlock Text="{Binding UpdateNote}" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="10,0,0,0" />
            </StackPanel>
            <TextBlock FontSize="11" Foreground="{DynamicResource TextTertiary}" Margin="0,8,0,0" TextWrapping="Wrap">
              <Run Text="{DynamicResource S.settings.about.dataDir}" /><Run Text="{Binding SettingsPath, Mode=OneWay}" />
            </TextBlock>
          </StackPanel>
        </Border>

        <!-- 关于开发者 -->
        <Border Style="{StaticResource Card}" Padding="16" Margin="0,12,0,18">
          <StackPanel>
            <TextBlock Text="{DynamicResource S.settings.aboutDev.title}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />
            <StackPanel Orientation="Horizontal">
              <Ellipse Width="68" Height="68" VerticalAlignment="Top">
                <Ellipse.Fill>
                  <ImageBrush ImageSource="{Binding AuthorAvatar}" Stretch="UniformToFill" />
                </Ellipse.Fill>
              </Ellipse>
              <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding AuthorName}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBlock FontSize="12" Margin="0,2,0,0">
                  <Run Text="{DynamicResource S.settings.aboutDev.github}" Foreground="{DynamicResource TextSecondary}" /><Hyperlink Command="{Binding OpenLinkCommand}" CommandParameter="https://github.com/Tommy131" Foreground="{DynamicResource Accent}">https://github.com/Tommy131</Hyperlink>
                </TextBlock>
                <TextBlock FontSize="12" Margin="0,2,0,0">
                  <Run Text="{DynamicResource S.settings.aboutDev.email}" Foreground="{DynamicResource TextSecondary}" /><Hyperlink Command="{Binding OpenLinkCommand}" CommandParameter="mailto:hanskijay@owoblog.com" Foreground="{DynamicResource Accent}">hanskijay@owoblog.com</Hyperlink>
                </TextBlock>
                <TextBlock FontSize="12" Margin="0,2,0,0">
                  <Run Text="{DynamicResource S.settings.aboutDev.donation}" Foreground="{DynamicResource TextSecondary}" /><Hyperlink Command="{Binding OpenLinkCommand}" CommandParameter="https://owoblog.com/donation" Foreground="{DynamicResource Accent}">https://owoblog.com/donation</Hyperlink>
                </TextBlock>
                <TextBlock FontSize="12" Margin="0,2,0,0">
                  <Run Text="{DynamicResource S.settings.aboutDev.service}" Foreground="{DynamicResource TextSecondary}" /><Hyperlink Command="{Binding OpenLinkCommand}" CommandParameter="https://owoblog.com/service" Foreground="{DynamicResource Accent}">https://owoblog.com/service</Hyperlink>
                </TextBlock>
                <TextBlock FontSize="12" Margin="0,2,0,0">
                  <Run Text="{DynamicResource S.settings.aboutDev.blog}" Foreground="{DynamicResource TextSecondary}" /><Hyperlink Command="{Binding OpenLinkCommand}" CommandParameter="https://owoblog.com" Foreground="{DynamicResource Accent}">https://owoblog.com</Hyperlink>
                </TextBlock>
              </StackPanel>
            </StackPanel>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
