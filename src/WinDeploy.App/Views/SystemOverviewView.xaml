<UserControl x:Class="WinDeploy.App.Views.SystemOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="系统概览" FontSize="20" FontWeight="SemiBold" />
      <TextBlock Text="本机硬件 / 系统健康一览：CPU、内存、磁盘（含 SMART）、电池、激活状态。" FontSize="13"
                 Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0" TextWrapping="Wrap" />
    </StackPanel>

    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
      <Button Content="↻ 刷新" Style="{StaticResource MiniButton}" Command="{Binding RefreshCommand}" />
      <Button Content="导出软件清单" Style="{StaticResource InfoButton}" Margin="8,0,0,0" Command="{Binding ExportInventoryCommand}" />
      <TextBlock Text="{Binding InventoryNote}" FontSize="12" Foreground="{DynamicResource TextTertiary}"
                 VerticalAlignment="Center" Margin="14,0,0,0" TextTrimming="CharacterEllipsis" />
    </StackPanel>

    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,14,0,0">
      <StackPanel>
        <!-- Summary card -->
        <Border Style="{StaticResource Card}" Padding="18,14">
          <StackPanel>
            <TextBlock Text="{Binding Os}" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
            <TextBlock Text="{Binding Machine}" FontSize="12.5" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0" TextWrapping="Wrap" />
            <Separator Margin="0,12" Background="{DynamicResource BorderSoft}" />
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0">
                <TextBlock Text="处理器" FontSize="11" Foreground="{DynamicResource TextTertiary}" />
                <TextBlock Text="{Binding Cpu}" FontSize="13" TextWrapping="Wrap" Margin="0,2,12,10" />
                <TextBlock Text="内存" FontSize="11" Foreground="{DynamicResource TextTertiary}" />
                <TextBlock Text="{Binding Ram}" FontSize="13" Margin="0,2,12,10" />
              </StackPanel>
              <StackPanel Grid.Column="1">
                <TextBlock Text="运行时间" FontSize="11" Foreground="{DynamicResource TextTertiary}" />
                <TextBlock Text="{Binding Uptime}" FontSize="13" Margin="0,2,0,10" />
                <TextBlock Text="激活 / 电池" FontSize="11" Foreground="{DynamicResource TextTertiary}" />
                <TextBlock FontSize="13" Margin="0,2,0,10">
                  <Run Text="{Binding Activation}" /><Run Text="  ·  " /><Run Text="{Binding Battery}" />
                </TextBlock>
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Drives -->
        <TextBlock Text="磁盘空间" FontSize="14" FontWeight="SemiBold" Margin="2,18,0,8" />
        <ItemsControl ItemsSource="{Binding Disks}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Style="{StaticResource Card}" Padding="14,11" Margin="0,0,0,8">
                <StackPanel>
                  <Grid>
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="{Binding Drive}" FontSize="14" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding Label}" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="8,0,0,0" VerticalAlignment="Center" />
                      <Border CornerRadius="6" Padding="6,1" Margin="8,0,0,0" Background="{DynamicResource FailBg}" VerticalAlignment="Center"
                              Visibility="{Binding Low, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="空间偏低" FontSize="10" Foreground="{DynamicResource FailFg}" />
                      </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding Text}" FontSize="12" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Right" />
                  </Grid>
                  <ProgressBar Value="{Binding UsedPercent, Mode=OneWay}" Maximum="100" Height="6" Margin="0,8,0,0"
                               Background="{DynamicResource PageBg}" Foreground="{DynamicResource Accent}" BorderThickness="0" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Physical disks / SMART (点击磁盘查看 SMART 详情) -->
        <TextBlock Text="物理磁盘健康 (SMART) · 点击磁盘查看详情" FontSize="14" FontWeight="SemiBold" Margin="2,14,0,8" />
        <ItemsControl ItemsSource="{Binding PhysicalDisks}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Style="{StaticResource Card}" Padding="14,10" Margin="0,0,0,8" Cursor="Hand"
                      ToolTip="点击查看该磁盘的 SMART / 可靠性数据">
                <Border.InputBindings>
                  <MouseBinding MouseAction="LeftClick"
                                Command="{Binding DataContext.ShowSmartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}" />
                </Border.InputBindings>
                <Grid>
                  <StackPanel>
                    <TextBlock Text="{Binding Name}" FontSize="13.5" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Detail}" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border CornerRadius="6" Padding="9,3" Background="{DynamicResource OkBg}">
                      <TextBlock Text="{Binding Health}" FontSize="12" Foreground="{DynamicResource OkFg}" />
                    </Border>
                    <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" Margin="8,0,0,0" />
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
