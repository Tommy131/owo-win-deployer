<UserControl x:Class="WinDeploy.App.Views.Deploy.ProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,12">
      <TextBlock Text="{DynamicResource S.nav.progress}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
        <Button Content="{DynamicResource S.progress.totalLog}" Style="{StaticResource MiniButton}" Command="{Binding OpenTotalLogCommand}"
                ToolTip="{DynamicResource S.progress.totalLogTip}" />
        <Button Content="{DynamicResource S.progress.clearRecords}" Style="{StaticResource DangerButton}" Command="{Binding ClearRecordsCommand}" Margin="8,0,0,0"
                ToolTip="{DynamicResource S.progress.clearRecordsTip}" />
      </StackPanel>
    </Grid>

    <!-- Overall -->
    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="16">
      <StackPanel>
        <Grid>
          <TextBlock Text="{Binding Overall}" FontSize="14" FontWeight="SemiBold" />
          <TextBlock Text="{Binding Eta}" FontSize="13" Foreground="{DynamicResource TextSecondary}"
                     HorizontalAlignment="Right" />
        </Grid>
        <ProgressBar Height="8" Margin="0,10,0,0" Minimum="0" Maximum="100" Value="{Binding Percent}"
                     Foreground="{DynamicResource Accent}" Background="{DynamicResource PageBg}" BorderThickness="0" />
        <UniformGrid Columns="4" Margin="0,12,0,0">
          <Border Background="{DynamicResource PageBg}" CornerRadius="8" Margin="0,0,6,0" Padding="8">
            <StackPanel>
              <TextBlock Text="{Binding OkCount}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
              <TextBlock Text="{DynamicResource S.progress.tile.ok}" FontSize="11" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center" />
            </StackPanel>
          </Border>
          <Border Background="{DynamicResource PageBg}" CornerRadius="8" Margin="3,0" Padding="8">
            <StackPanel>
              <TextBlock Text="{Binding RunningCount}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
              <TextBlock Text="{DynamicResource S.progress.tile.running}" FontSize="11" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center" />
            </StackPanel>
          </Border>
          <Border Background="{DynamicResource PageBg}" CornerRadius="8" Margin="3,0" Padding="8">
            <StackPanel>
              <TextBlock Text="{Binding QueuedCount}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
              <TextBlock Text="{DynamicResource S.progress.tile.queued}" FontSize="11" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center" />
            </StackPanel>
          </Border>
          <Border Background="{DynamicResource PageBg}" CornerRadius="8" Margin="6,0,0,0" Padding="8">
            <StackPanel>
              <TextBlock Text="{Binding FailedCount}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
              <TextBlock Text="{DynamicResource S.progress.tile.failed}" FontSize="11" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center" />
            </StackPanel>
          </Border>
        </UniformGrid>
      </StackPanel>
    </Border>

    <!-- Current task -->
    <Border Grid.Row="2" Style="{StaticResource Card}" Padding="14" Margin="0,12,0,0"
            BorderBrush="{DynamicResource Accent}"
            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
      <Grid>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="{Binding CurrentLabel}" FontSize="12" Foreground="{DynamicResource TextSecondary}" />
          <TextBlock Text="{Binding Current}" FontSize="15" FontWeight="SemiBold" Margin="0,2,0,0" />
          <TextBlock Text="{Binding LiveProgress}" FontFamily="Consolas" FontSize="12"
                     Foreground="{DynamicResource Accent}" Margin="0,3,0,0" />
        </StackPanel>
        <Button Content="{DynamicResource S.common.cancel}" Style="{StaticResource DangerButton}" Command="{Binding CancelCommand}"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                ToolTip="{DynamicResource S.progress.cancelTip}" />
      </Grid>
    </Border>

    <!-- Task list -->
    <Border Grid.Row="3" Style="{StaticResource Card}" Padding="14,4,14,4" Margin="0,12,0,0">
      <!-- Margin right -10 / Padding right 10: scrollbar hugs the card's right edge, rows stay put. -->
      <ScrollViewer x:Name="TaskScroller" VerticalScrollBarVisibility="Auto" Margin="0,0,-10,0" Padding="0,0,10,0">
        <ItemsControl ItemsSource="{Binding Items}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border BorderBrush="{DynamicResource BorderSoft}" BorderThickness="0,0,0,1" Padding="2,9"
                      Background="Transparent" Cursor="Hand" ToolTip="{DynamicResource S.progress.rowTip}">
                <Border.InputBindings>
                  <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleDetailsCommand}" />
                </Border.InputBindings>
                <StackPanel>
                  <Grid>
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="{Binding ExpandGlyph}" FontSize="10" Width="14" VerticalAlignment="Center"
                                 Foreground="{DynamicResource TextTertiary}" />
                      <TextBlock Text="{Binding Name}" FontSize="13" VerticalAlignment="Center" />
                      <TextBlock Text="{Binding Method}" FontSize="11" Foreground="{DynamicResource TextTertiary}"
                                 Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <Border x:Name="Pill" HorizontalAlignment="Right" CornerRadius="10" Padding="9,2"
                            Background="{DynamicResource PageBg}">
                      <TextBlock x:Name="PillText" Text="{Binding Status}" FontSize="11"
                                 Foreground="{DynamicResource TextSecondary}" />
                    </Border>
                  </Grid>
                  <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                    <TextBlock Text="{Binding TimeText}" FontSize="11" Foreground="{DynamicResource TextTertiary}" />
                    <TextBlock Text="{Binding DurationText}" FontSize="11" Foreground="{DynamicResource TextTertiary}" Margin="12,0,0,0" />
                  </StackPanel>
                  <Border Margin="0,6,0,0" Padding="10" CornerRadius="6" Background="{DynamicResource PageBg}"
                          Visibility="{Binding IsDetailsOpen, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding Details}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11.5"
                                     Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,1" />
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </Border>
                </StackPanel>
              </Border>
              <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="ok">
                  <Setter TargetName="Pill" Property="Background" Value="{DynamicResource OkBg}" />
                  <Setter TargetName="PillText" Property="Foreground" Value="{DynamicResource OkFg}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="running">
                  <Setter TargetName="Pill" Property="Background" Value="{DynamicResource AccentBg}" />
                  <Setter TargetName="PillText" Property="Foreground" Value="{DynamicResource Accent}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="failed">
                  <Setter TargetName="Pill" Property="Background" Value="{DynamicResource FailBg}" />
                  <Setter TargetName="PillText" Property="Foreground" Value="{DynamicResource FailFg}" />
                </DataTrigger>
              </DataTemplate.Triggers>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <!-- Log -->
    <Border Grid.Row="4" Background="{DynamicResource PageBg}" CornerRadius="8" Padding="12" Margin="0,12,0,0" MaxHeight="120">
      <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
        <TextBlock Text="{Binding Log}" FontFamily="Consolas" FontSize="12"
                   Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" />
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>
