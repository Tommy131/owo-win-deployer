<UserControl x:Class="WinDeploy.App.Views.Deploy.ConfigSyncView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="{DynamicResource S.cfgsync.title}" FontSize="20" FontWeight="SemiBold" />
      <TextBlock Text="{DynamicResource S.cfgsync.subtitle}"
                 FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0" TextWrapping="Wrap" />
    </StackPanel>

    <!-- Margin right -24 / Padding right 24: scrollbar flush at the page's outer edge, content unchanged. -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,12,-24,0" Padding="0,0,24,0">
      <StackPanel>

        <Border Style="{StaticResource Card}" Padding="14">
          <StackPanel>
            <TextBlock Text="{DynamicResource S.cfgsync.toApply}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
            <ItemsControl ItemsSource="{Binding Items}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border BorderBrush="{DynamicResource BorderSoft}" BorderThickness="0,0,0,1" Padding="2,7">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="13" VerticalAlignment="Center" />
                      <Border Grid.Column="1" Background="{DynamicResource PageBg}" CornerRadius="6" Padding="6,2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ApplyWhen}" FontSize="11" Foreground="{DynamicResource TextSecondary}" />
                      </Border>
                      <TextBlock Grid.Column="2" Text="{Binding Target}" FontSize="12" Foreground="{DynamicResource TextTertiary}"
                                 Margin="10,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
              <CheckBox Content="{DynamicResource S.cfgsync.includeAsk}" IsChecked="{Binding IncludeAsk}" VerticalAlignment="Center" />
              <Button Content="{DynamicResource S.cfgsync.apply}" Style="{StaticResource PrimaryButton}" Margin="14,0,0,0" Command="{Binding ApplyCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource Card}" Padding="14" Margin="0,12,0,0">
          <StackPanel>
            <TextBlock Text="{DynamicResource S.cfgsync.ssh.title}" FontSize="14" FontWeight="SemiBold" />
            <TextBlock Text="{DynamicResource S.cfgsync.ssh.subtitle}"
                       FontSize="12" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,4,0,8" />
            <StackPanel Orientation="Horizontal">
              <CheckBox Content="{DynamicResource S.cfgsync.ssh.register}" IsChecked="{Binding RegisterSsh}" VerticalAlignment="Center" />
              <Button Content="{DynamicResource S.cfgsync.ssh.generate}" Style="{StaticResource PrimaryButton}" Margin="14,0,0,0" Command="{Binding SshCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <TextBlock Text="{DynamicResource S.cfgsync.processing}" Foreground="{DynamicResource Accent}" Margin="2,12,0,0"
                   Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />

        <ItemsControl ItemsSource="{Binding Results}" Margin="0,10,0,0">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border BorderBrush="{DynamicResource BorderSoft}" BorderThickness="0,0,0,1" Padding="2,8">
                <Grid>
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Name}" FontSize="13" />
                    <TextBlock Text="{Binding Message}" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                               Margin="10,0,0,0" VerticalAlignment="Center" />
                  </StackPanel>
                  <Border x:Name="Pill" HorizontalAlignment="Right" CornerRadius="10" Padding="9,2" Background="{DynamicResource OkBg}">
                    <TextBlock x:Name="PillText" Text="{DynamicResource S.cfgsync.status.done}" FontSize="11" Foreground="{DynamicResource OkFg}" />
                  </Border>
                </Grid>
              </Border>
              <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="failed">
                  <Setter TargetName="Pill" Property="Background" Value="{DynamicResource FailBg}" />
                  <Setter TargetName="PillText" Property="Foreground" Value="{DynamicResource FailFg}" />
                  <Setter TargetName="PillText" Property="Text" Value="{DynamicResource S.cfgsync.status.failed}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="skip">
                  <Setter TargetName="Pill" Property="Background" Value="{DynamicResource PageBg}" />
                  <Setter TargetName="PillText" Property="Foreground" Value="{DynamicResource TextSecondary}" />
                  <Setter TargetName="PillText" Property="Text" Value="{DynamicResource S.cfgsync.status.skip}" />
                </DataTrigger>
              </DataTemplate.Triggers>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
