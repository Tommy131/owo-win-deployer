<UserControl x:Class="WinDeploy.App.Views.Deploy.InstallCenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header / top bar -->
    <Grid Grid.Row="0" Margin="24,18,24,8">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,0">
        <TextBlock Text="{DynamicResource S.nav.installCenter}" FontSize="20" FontWeight="SemiBold" />
        <TextBlock Text="{Binding Subtitle}" FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0"
                   TextTrimming="CharacterEllipsis" />
      </StackPanel>

      <!-- action buttons: full width below the title row so they fit on one line, wrapping only when truly narrow -->
      <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,0,0">
        <!-- 统一用右/下外边距（不用左边距），换行后每一行都从左侧对齐 -->
        <WrapPanel>
          <Button Content="{DynamicResource S.install.refresh}" Style="{StaticResource MiniButton}" Command="{Binding RefreshCommand}" Margin="0,0,8,6"
                  ToolTip="{DynamicResource S.install.refreshTip}" />
          <Border Width="1" Background="{DynamicResource BorderSoft}" Margin="2,2,10,8" />
          <Button Content="{DynamicResource S.install.selectAll}" Style="{StaticResource MiniButton}" Command="{Binding SelectAllCommand}" Margin="0,0,8,6" />
          <Button Content="{DynamicResource S.install.invert}" Style="{StaticResource MiniButton}" Command="{Binding InvertCommand}" Margin="0,0,8,6" />
          <Button Content="{DynamicResource S.install.restore}" Style="{StaticResource MiniButton}" Command="{Binding RestoreCommand}" Margin="0,0,8,6"
                  ToolTip="{DynamicResource S.install.restoreTip}" />
          <Button Content="{DynamicResource S.install.setPath}" Style="{StaticResource MiniButton}" Click="SetPath_Click" Margin="0,0,8,6"
                  ToolTip="{DynamicResource S.install.setPathTip}" />
          <Border Width="1" Background="{DynamicResource BorderSoft}" Margin="2,2,10,8" />
          <Button Content="{Binding UpdateLabel}" Style="{StaticResource MiniButton}" Command="{Binding UpdateSelectedCommand}" Margin="0,0,8,6"
                  ToolTip="{DynamicResource S.install.updateSelectedTip}" />
          <Button Content="{Binding UpdateToggleLabel}" Style="{StaticResource MiniButton}" Command="{Binding ToggleUpdatesCommand}" Margin="0,0,8,6"
                  Visibility="{Binding HasUpdates, Converter={StaticResource BoolToVis}}"
                  ToolTip="{DynamicResource S.install.updatesTip}" />
          <Border Width="1" Background="{DynamicResource BorderSoft}" Margin="2,2,10,8" />
          <ToggleButton x:Name="GroupFilterBtn" Content="{Binding GroupFilterLabel}" Style="{StaticResource MiniToggle}" Margin="0,0,8,6"
                        ToolTip="{DynamicResource S.install.filterGroupsTip}" />
          <Popup PlacementTarget="{Binding ElementName=GroupFilterBtn}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                 IsOpen="{Binding IsChecked, ElementName=GroupFilterBtn}">
            <Border Style="{StaticResource Card}" Padding="10" Margin="0,4,0,0" MinWidth="180">
              <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="2,0,2,8">
                  <TextBlock Text="{DynamicResource S.install.filterTitle}" FontSize="12.5" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <Button Content="{DynamicResource S.install.selectAll}" Style="{StaticResource MiniButton}" Command="{Binding ShowAllGroupsCommand}" Margin="12,0,0,0" />
                  <Button Content="{DynamicResource S.install.filterClear}" Style="{StaticResource MiniButton}" Command="{Binding HideAllGroupsCommand}" Margin="6,0,0,0" />
                </StackPanel>
                <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
                  <ItemsControl ItemsSource="{Binding CategoryFilters}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <CheckBox Content="{Binding Title}" IsChecked="{Binding IsChecked, Mode=TwoWay}" FontSize="13" Margin="2,4" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </StackPanel>
            </Border>
          </Popup>
        </WrapPanel>

        <TextBlock Text="{Binding PathNote}" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,0" TextWrapping="Wrap" />
      </StackPanel>

      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
        <!-- 搜索框（带水印 + 说明） -->
        <Grid Width="150" Height="32" ToolTip="{DynamicResource S.install.searchTip}">
          <TextBox VerticalContentAlignment="Center" Padding="8,0"
                   Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
          <TextBlock Text="{DynamicResource S.install.searchWatermark}" Foreground="{DynamicResource TextTertiary}" Margin="10,0,0,0"
                     VerticalAlignment="Center" IsHitTestVisible="False">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding SearchText}" Value=""><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </Grid>

        <!-- 预设下拉（带水印 + 说明） -->
        <Grid Width="120" Height="32" Margin="8,0,0,0" ToolTip="{DynamicResource S.install.profileTip}">
          <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}" />
          <TextBlock Text="{DynamicResource S.install.profileWatermark}" Foreground="{DynamicResource TextTertiary}" Margin="9,0,0,0"
                     VerticalAlignment="Center" IsHitTestVisible="False">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding SelectedProfile}" Value="{x:Null}"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </Grid>

        <Button Content="{Binding StartLabel}" Style="{StaticResource PrimaryButton}"
                Margin="8,0,0,0" Command="{Binding StartCommand}" />
      </StackPanel>
    </Grid>

    <!-- Error banner -->
    <Border Grid.Row="1" Margin="24,8" VerticalAlignment="Top" Padding="14,10" CornerRadius="8"
            Background="{DynamicResource FailBg}"
            Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
      <TextBlock Text="{Binding LoadError}" Foreground="{DynamicResource FailFg}" TextWrapping="Wrap" />
    </Border>

    <!-- Loading（先检测完已安装状态，再显示列表） -->
    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
      <ProgressBar IsIndeterminate="True" Width="220" Height="4"
                   Foreground="{DynamicResource Accent}" Background="{DynamicResource PageBg}" BorderThickness="0" />
      <TextBlock Text="{DynamicResource S.install.detecting}" FontSize="13" Foreground="{DynamicResource TextSecondary}"
                 HorizontalAlignment="Center" Margin="0,12,0,0" />
    </StackPanel>

    <!-- Category groups -->
    <ScrollViewer x:Name="Scroller" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,4,18,18"
                  ScrollChanged="Scroller_ScrollChanged"
                  Visibility="{Binding IsReady, Converter={StaticResource BoolToVis}}">
      <ItemsControl ItemsSource="{Binding Groups}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <StackPanel Margin="0,0,0,6"
                        Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}">
              <StackPanel Orientation="Horizontal" Margin="0,12,0,8">
                <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" />
                <TextBlock Text="{Binding CountText}" FontSize="12" Foreground="{DynamicResource TextTertiary}"
                           Margin="10,0,0,0" VerticalAlignment="Center" />
              </StackPanel>

              <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Style="{StaticResource Card}" Width="188" MinHeight="150" Margin="0,0,10,10" Padding="12"
                            Cursor="Hand"
                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}">
                      <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding DataContext.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      CommandParameter="{Binding}" />
                      </Border.InputBindings>
                      <Border.ContextMenu>
                        <ContextMenu Style="{StaticResource ThemedContextMenu}">
                          <MenuItem Header="{DynamicResource S.install.ctx.install}" Style="{StaticResource ThemedMenuItem}"
                                    Visibility="{Binding NotInstalled, Converter={StaticResource BoolToVis}}"
                                    Command="{Binding PlacementTarget.Tag.InstallCardCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                    CommandParameter="{Binding}">
                            <MenuItem.Icon><TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextSecondary}" /></MenuItem.Icon>
                          </MenuItem>
                          <MenuItem Header="{DynamicResource S.install.ctx.checkUpdate}" Style="{StaticResource ThemedMenuItem}"
                                    Visibility="{Binding CanUpdate, Converter={StaticResource BoolToVis}}"
                                    Command="{Binding PlacementTarget.Tag.UpdateCardCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                    CommandParameter="{Binding}">
                            <MenuItem.Icon><TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextSecondary}" /></MenuItem.Icon>
                          </MenuItem>
                          <MenuItem Header="{DynamicResource S.install.ctx.launch}" Style="{StaticResource ThemedMenuItem}"
                                    Visibility="{Binding ShowLaunch, Converter={StaticResource BoolToVis}}"
                                    Command="{Binding PlacementTarget.Tag.LaunchCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                    CommandParameter="{Binding}">
                            <MenuItem.Icon><TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextSecondary}" /></MenuItem.Icon>
                          </MenuItem>
                          <MenuItem Header="{DynamicResource S.install.ctx.stop}" Style="{StaticResource ThemedMenuItem}"
                                    Visibility="{Binding ShowStop, Converter={StaticResource BoolToVis}}"
                                    Command="{Binding PlacementTarget.Tag.StopCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                    CommandParameter="{Binding}">
                            <MenuItem.Icon><TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextSecondary}" /></MenuItem.Icon>
                          </MenuItem>
                          <MenuItem Header="{DynamicResource S.install.ctx.restart}" Style="{StaticResource ThemedMenuItem}"
                                    Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}"
                                    Command="{Binding PlacementTarget.Tag.RestartCardCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                    CommandParameter="{Binding}">
                            <MenuItem.Icon><TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextSecondary}" /></MenuItem.Icon>
                          </MenuItem>
                          <Separator Style="{StaticResource ThemedSeparator}" />
                          <MenuItem Header="{DynamicResource S.install.ctx.openDir}" Style="{StaticResource ThemedMenuItem}"
                                    Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}"
                                    Command="{Binding PlacementTarget.Tag.OpenDirCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                    CommandParameter="{Binding}">
                            <MenuItem.Icon><TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextSecondary}" /></MenuItem.Icon>
                          </MenuItem>
                          <MenuItem Header="{DynamicResource S.install.ctx.homepage}" Style="{StaticResource ThemedMenuItem}"
                                    ToolTip="{DynamicResource S.install.ctx.homepageTip}"
                                    Command="{Binding PlacementTarget.Tag.OpenHomepageCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                    CommandParameter="{Binding}">
                            <MenuItem.Icon><TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextSecondary}" /></MenuItem.Icon>
                          </MenuItem>
                          <MenuItem Header="{DynamicResource S.install.ctx.detail}" Style="{StaticResource ThemedMenuItem}"
                                    Command="{Binding PlacementTarget.Tag.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                    CommandParameter="{Binding}">
                            <MenuItem.Icon><TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextSecondary}" /></MenuItem.Icon>
                          </MenuItem>
                          <Separator Style="{StaticResource ThemedSeparator}" />
                          <MenuItem Header="{DynamicResource S.install.ctx.uninstall}" Style="{StaticResource ThemedMenuItem}"
                                    Visibility="{Binding CanUninstall, Converter={StaticResource BoolToVis}}"
                                    Command="{Binding PlacementTarget.Tag.UninstallCardCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                    CommandParameter="{Binding}">
                            <MenuItem.Icon><TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextSecondary}" /></MenuItem.Icon>
                          </MenuItem>
                        </ContextMenu>
                      </Border.ContextMenu>
                      <StackPanel>
                        <Grid>
                          <Grid Width="36" Height="36" HorizontalAlignment="Left">
                            <Border CornerRadius="8" Background="{Binding ChipBackground}"
                                    Visibility="{Binding ShowLetter, Converter={StaticResource BoolToVis}}">
                              <TextBlock Text="{Binding Badge}" FontSize="17" FontWeight="SemiBold"
                                         Foreground="{Binding ChipForeground}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Image Source="{Binding IconImage}" Stretch="Uniform" Margin="2"
                                   Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                          </Grid>
                          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <Border CornerRadius="8" Padding="6,1" Margin="0,0,6,0" VerticalAlignment="Center"
                                    Background="{DynamicResource AccentBg}"
                                    Visibility="{Binding ShowUpdateBadge, Converter={StaticResource BoolToVis}}"
                                    ToolTip="{DynamicResource S.install.updateAvailTip}">
                              <TextBlock Text="{DynamicResource S.install.badge.update}" FontSize="10" Foreground="{DynamicResource Accent}" />
                            </Border>
                            <Button Style="{StaticResource CardIconButton}" Content="▶" Margin="0,0,6,0"
                                    Visibility="{Binding ShowLaunch, Converter={StaticResource BoolToVis}}"
                                    Command="{Binding DataContext.LaunchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}" ToolTip="{DynamicResource S.install.launchTip}" />
                            <Button Style="{StaticResource CardStopButton}" Content="■" Margin="0,0,6,0"
                                    Visibility="{Binding ShowStop, Converter={StaticResource BoolToVis}}"
                                    Command="{Binding DataContext.StopCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}" ToolTip="{DynamicResource S.install.stopProcTip}" />
                            <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" />
                          </StackPanel>
                        </Grid>
                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Margin="0,9,0,0"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Summary}" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                                   TextWrapping="Wrap" Height="32" Margin="0,2,0,0" />
                        <WrapPanel Margin="0,8,0,0">
                          <Border Background="{DynamicResource PageBg}" CornerRadius="6" Padding="6,2" Margin="0,0,5,4">
                            <TextBlock Text="{Binding Method}" FontSize="11" Foreground="{DynamicResource TextSecondary}" />
                          </Border>
                          <Border CornerRadius="6" Padding="6,2" Margin="0,0,5,4" Background="{DynamicResource OkBg}"
                                  Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="{DynamicResource OkFg}" />
                          </Border>
                          <Border CornerRadius="6" Padding="6,2" Margin="0,0,5,4" Background="{DynamicResource AccentBg}"
                                  Visibility="{Binding ShowStop, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{DynamicResource S.install.badge.running}" FontSize="11" Foreground="{DynamicResource Accent}" />
                          </Border>
                        </WrapPanel>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
