<UserControl x:Class="WinDeploy.App.Views.Deploy.ExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="{DynamicResource S.export.title}" FontSize="20" FontWeight="SemiBold" />
      <TextBlock Text="{DynamicResource S.export.subtitle}"
                 FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0" TextWrapping="Wrap" />
    </StackPanel>

    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,14,0,0">
      <Button Content="{DynamicResource S.export.capture}" Style="{StaticResource PrimaryButton}" Command="{Binding ExportCommand}" />
      <TextBlock Text="{DynamicResource S.export.processing}" Foreground="{DynamicResource Accent}" Margin="14,0,0,0" VerticalAlignment="Center"
                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
      <Border Width="1" Background="{DynamicResource BorderSoft}" Margin="18,2,18,2" />
      <CheckBox Content="{DynamicResource S.export.schedule}" IsChecked="{Binding ScheduleEnabled}" VerticalAlignment="Center"
                ToolTip="{DynamicResource S.export.schedule.tip}" />
      <ComboBox SelectedIndex="{Binding ScheduleFreqIndex}" Width="120" Margin="8,0,0,0" VerticalAlignment="Center"
                IsEnabled="{Binding ScheduleEnabled}">
        <ComboBoxItem Content="{DynamicResource S.export.schedule.daily}" />
        <ComboBoxItem Content="{DynamicResource S.export.schedule.weekly}" />
        <ComboBoxItem Content="{DynamicResource S.export.schedule.onlogon}" />
      </ComboBox>
      <TextBlock Text="{Binding ScheduleNote}" Foreground="{DynamicResource TextSecondary}" Margin="10,0,0,0" VerticalAlignment="Center" />
    </StackPanel>

    <Border Grid.Row="2" Style="{StaticResource Card}" Padding="8,6" Margin="0,14,0,0">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Results}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Expander Margin="0,2" IsEnabled="{Binding HasFiles}" HorizontalContentAlignment="Stretch">
                <Expander.Header>
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border x:Name="Pill" CornerRadius="10" Padding="8,1" Margin="10,0,0,0" Background="{DynamicResource OkBg}" VerticalAlignment="Center">
                      <TextBlock x:Name="PillText" Text="{DynamicResource S.export.status.ok}" FontSize="11" Foreground="{DynamicResource OkFg}" />
                    </Border>
                    <TextBlock Text="{Binding Message}" FontSize="12" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="10,0,0,0" />
                  </StackPanel>
                </Expander.Header>
                <ItemsControl ItemsSource="{Binding Files}" Margin="26,4,0,8">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                          <TextBlock Text="{Binding Path}" FontFamily="Consolas" FontSize="12" />
                          <TextBlock Text="{Binding SizeText}" FontSize="11" Foreground="{DynamicResource TextTertiary}" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <Border Background="{DynamicResource PageBg}" CornerRadius="6" Padding="10,8" Margin="0,5,0,0" MaxHeight="150">
                          <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding Preview}" FontFamily="Consolas" FontSize="11"
                                       Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" />
                          </ScrollViewer>
                        </Border>
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Expander>
              <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="failed">
                  <Setter TargetName="Pill" Property="Background" Value="{DynamicResource FailBg}" />
                  <Setter TargetName="PillText" Property="Foreground" Value="{DynamicResource FailFg}" />
                  <Setter TargetName="PillText" Property="Text" Value="{DynamicResource S.export.status.failed}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="skip">
                  <Setter TargetName="Pill" Property="Background" Value="{DynamicResource PageBg}" />
                  <Setter TargetName="PillText" Property="Foreground" Value="{DynamicResource TextSecondary}" />
                  <Setter TargetName="PillText" Property="Text" Value="{DynamicResource S.export.status.skip}" />
                </DataTrigger>
              </DataTemplate.Triggers>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <Border Grid.Row="3" Background="{DynamicResource OkBg}" CornerRadius="8" Padding="12" Margin="0,12,0,0"
            Visibility="{Binding Done, Converter={StaticResource BoolToVis}}">
      <TextBlock Text="{DynamicResource S.export.done}" Foreground="{DynamicResource OkFg}" />
    </Border>
  </Grid>
</UserControl>
