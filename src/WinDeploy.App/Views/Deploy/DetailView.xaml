<UserControl x:Class="WinDeploy.App.Views.Deploy.DetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Button Grid.Row="0" Content="{DynamicResource S.detail.back}" Command="{Binding BackCommand}"
            HorizontalAlignment="Left" Style="{StaticResource PrimaryButton}" />

    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,16,0,0">
      <Grid Width="56" Height="56">
        <Border CornerRadius="12" Background="{Binding ChipBackground}"
                Visibility="{Binding ShowLetter, Converter={StaticResource BoolToVis}}">
          <TextBlock Text="{Binding Badge}" FontSize="26" FontWeight="SemiBold" Foreground="{Binding ChipForeground}"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <Image Source="{Binding IconImage}" Stretch="Uniform" Margin="3"
               Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}"
               RenderOptions.BitmapScalingMode="HighQuality" />
      </Grid>
      <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="{Binding Name}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
          <Border CornerRadius="10" Padding="9,2" Margin="10,0,0,0" VerticalAlignment="Center" Background="{DynamicResource PageBg}">
            <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="{DynamicResource TextSecondary}" />
          </Border>
        </StackPanel>
        <TextBlock Text="{Binding Summary}" FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0" />
      </StackPanel>
    </StackPanel>

    <!-- Margin right -24 / Padding right 24: scrollbar flush at the page's outer edge, content unchanged. -->
    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,16,-24,0" Padding="0,0,24,0">
     <StackPanel>
      <Border Style="{StaticResource Card}" Padding="18">
       <StackPanel>
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="{DynamicResource S.detail.field.version}" FontSize="13" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
          <StackPanel Grid.Column="1" Orientation="Horizontal"
                      Visibility="{Binding CanChooseVersion, Converter={StaticResource BoolToVis}}">
            <ComboBox ItemsSource="{Binding Versions}" SelectedItem="{Binding SelectedVersion}" Width="180"
                      ToolTip="{DynamicResource S.detail.version.tip}" />
            <TextBlock Text="{Binding InstalledNote}" FontSize="12" Foreground="{DynamicResource TextTertiary}"
                       VerticalAlignment="Center" Margin="10,0,0,0" />
          </StackPanel>
          <TextBlock Grid.Column="1" Text="{Binding Version}" FontSize="13" VerticalAlignment="Center"
                     Visibility="{Binding CannotChooseVersion, Converter={StaticResource BoolToVis}}" />
        </Grid>
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="{DynamicResource S.detail.field.size}" FontSize="13" Foreground="{DynamicResource TextSecondary}" />
          <TextBlock Grid.Column="1" Text="{Binding Size}" FontSize="13" />
        </Grid>
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="{DynamicResource S.detail.field.installDate}" FontSize="13" Foreground="{DynamicResource TextSecondary}" />
          <TextBlock Grid.Column="1" Text="{Binding InstallDate}" FontSize="13" />
        </Grid>
        <Grid Margin="0,0,0,12" Visibility="{Binding HasInstallLocation, Converter={StaticResource BoolToVis}}">
          <Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="{DynamicResource S.detail.field.installLocation}" FontSize="13" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
          <StackPanel Grid.Column="1" Orientation="Horizontal">
            <TextBlock Text="{Binding InstallLocation}" FontSize="13" FontFamily="Consolas" TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center" MaxWidth="300" ToolTip="{Binding InstallLocation}" />
            <Button Content="{DynamicResource S.common.open}" Style="{StaticResource MiniButton}" Command="{Binding OpenLocationCommand}" Margin="10,0,0,0" />
          </StackPanel>
        </Grid>
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="{DynamicResource S.detail.field.publisher}" FontSize="13" Foreground="{DynamicResource TextSecondary}" />
          <TextBlock Grid.Column="1" Text="{Binding Publisher}" FontSize="13" TextTrimming="CharacterEllipsis" />
        </Grid>
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="{DynamicResource S.detail.field.source}" FontSize="13" Foreground="{DynamicResource TextSecondary}" />
          <TextBlock Grid.Column="1" Text="{Binding Source}" FontSize="13" />
        </Grid>
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="{DynamicResource S.detail.field.id}" FontSize="13" Foreground="{DynamicResource TextSecondary}" />
          <TextBlock Grid.Column="1" Text="{Binding PackageId}" FontSize="13" FontFamily="Consolas" TextTrimming="CharacterEllipsis" />
        </Grid>
        <Grid>
          <Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="{DynamicResource S.detail.field.homepage}" FontSize="13" Foreground="{DynamicResource TextSecondary}" />
          <TextBlock Grid.Column="1" FontSize="13" TextTrimming="CharacterEllipsis">
            <Hyperlink Command="{Binding OpenHomepageCommand}"><Run Text="{Binding Homepage, Mode=OneWay}" /></Hyperlink>
          </TextBlock>
        </Grid>
       </StackPanel>
      </Border>

      <Border Style="{StaticResource Card}" Padding="18" Margin="0,14,0,0">
        <StackPanel>
          <TextBlock Text="{DynamicResource S.detail.actions}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10" />

          <StackPanel Margin="0,0,0,12" Visibility="{Binding CanSetPath, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{DynamicResource S.detail.installPath}" FontSize="12" Foreground="{DynamicResource TextSecondary}" />
            <TextBox Text="{Binding InstallPath, UpdateSourceTrigger=PropertyChanged}" Height="32" VerticalContentAlignment="Center" Padding="8,0" Margin="0,3,0,0" />
            <TextBlock Text="{Binding PathHint}" FontSize="11" Foreground="{DynamicResource TextTertiary}" Margin="0,3,0,0" TextWrapping="Wrap" />
          </StackPanel>

          <!-- 运行：启动（绿）/ 结束进程（红，仅运行时）/ 重启（蓝） -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,10" Visibility="{Binding CanLaunch, Converter={StaticResource BoolToVis}}">
            <Button Content="{DynamicResource S.detail.launch}" Style="{StaticResource OkButton}" Command="{Binding LaunchCommand}" Margin="0,0,8,0" ToolTip="{DynamicResource S.detail.launch.tip}" />
            <Button Content="{DynamicResource S.detail.stop}" Style="{StaticResource DangerButton}" Command="{Binding StopCommand}" Margin="0,0,8,0"
                    Visibility="{Binding CanStop, Converter={StaticResource BoolToVis}}" ToolTip="{DynamicResource S.detail.stop.tip}" />
            <Button Content="{DynamicResource S.detail.restart}" Style="{StaticResource InfoButton}" Command="{Binding RestartCommand}" ToolTip="{DynamicResource S.detail.restart.tip}" />
          </StackPanel>

          <!-- 管理：前往官网下载 / 安装 / 检查更新（蓝）/ 降级（橙）/ 卸载（红） · 随版本选择器联动 -->
          <StackPanel Orientation="Horizontal">
            <Button Content="{DynamicResource S.detail.manualDownload}" Style="{StaticResource PrimaryButton}" Command="{Binding OpenHomepageCommand}" Margin="0,0,8,0"
                    Visibility="{Binding ShowManualDownload, Converter={StaticResource BoolToVis}}"
                    ToolTip="{DynamicResource S.detail.manualDownload.tip}" />
            <Button Content="{DynamicResource S.detail.install}" Style="{StaticResource PrimaryButton}" Command="{Binding InstallCommand}" Margin="0,0,8,0"
                    Visibility="{Binding ShowInstall, Converter={StaticResource BoolToVis}}" ToolTip="{DynamicResource S.detail.install.tip}" />
            <Button Content="{DynamicResource S.detail.update}" Style="{StaticResource InfoButton}" Command="{Binding UpdateCommand}" Margin="0,0,8,0"
                    Visibility="{Binding ShowUpdate, Converter={StaticResource BoolToVis}}"
                    ToolTip="{DynamicResource S.detail.update.tip}" />
            <Button Content="{DynamicResource S.detail.downgrade}" Style="{StaticResource WarnButton}" Command="{Binding DowngradeCommand}" Margin="0,0,8,0"
                    Visibility="{Binding ShowDowngrade, Converter={StaticResource BoolToVis}}"
                    ToolTip="{DynamicResource S.detail.downgrade.tip}" />
            <Button Content="{DynamicResource S.detail.uninstall}" Style="{StaticResource DangerButton}" Command="{Binding UninstallCommand}"
                    Visibility="{Binding CanUninstall, Converter={StaticResource BoolToVis}}" ToolTip="{DynamicResource S.detail.uninstall.tip}" />
          </StackPanel>

          <!-- 开发环境：手动配置环境变量（PATH / JAVA_HOME 等） -->
          <StackPanel Margin="0,12,0,0" Visibility="{Binding ShowEnvButton, Converter={StaticResource BoolToVis}}">
            <Button Content="{DynamicResource S.detail.envVars}" Style="{StaticResource MiniButton}" Command="{Binding EnvVarsCommand}"
                    HorizontalAlignment="Left" ToolTip="{DynamicResource S.detail.envVars.tip}" />
            <TextBlock Text="{DynamicResource S.detail.envVars.hint}"
                       FontSize="11" Foreground="{DynamicResource TextTertiary}" TextWrapping="Wrap" Margin="0,4,0,0" />
          </StackPanel>
        </StackPanel>
      </Border>
     </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
