<UserControl x:Class="WinDeploy.App.Views.Clip.ClipPeersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- status + start/stop -->
    <Border Grid.Row="0" Style="{StaticResource Card}" Padding="16,13">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="{DynamicResource S.clip.status.label}" FontSize="14" Foreground="{DynamicResource TextSecondary}" />
            <TextBlock Text="{Binding StatusText}" FontSize="14" FontWeight="SemiBold" Margin="4,0,0,0">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Foreground" Value="{DynamicResource TextTertiary}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Running}" Value="True">
                      <Setter Property="Foreground" Value="{DynamicResource OkFg}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="{Binding CapacityText}" FontSize="12.5" Foreground="{DynamicResource TextTertiary}" Margin="14,0,0,0" VerticalAlignment="Center" />
          </StackPanel>
          <TextBlock Text="{Binding SelfText}" FontSize="12.5" Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,0" />
          <TextBlock Text="{Binding LocalAddresses}" FontSize="12" FontFamily="Consolas" Foreground="{DynamicResource TextTertiary}" Margin="0,3,0,0" TextWrapping="Wrap" />
          <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
            <TextBlock Text="{DynamicResource S.clip.peers.nicLabel}" FontSize="12" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox ItemsSource="{Binding Nics}" SelectedItem="{Binding SelectedNic}" DisplayMemberPath="Label" MinWidth="220" MaxWidth="340" />
          </StackPanel>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <Button Content="{DynamicResource S.clip.peers.start}" Style="{StaticResource OkButton}" Margin="0,0,8,0" Command="{Binding StartCommand}" />
          <Button Content="{DynamicResource S.clip.peers.stop}" Style="{StaticResource DangerButton}" Command="{Binding StopCommand}" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- pending invite banner -->
    <Border Grid.Row="1" Margin="0,12,0,0" CornerRadius="10" BorderThickness="1"
            Background="{DynamicResource AccentBg}" BorderBrush="{DynamicResource Accent}" Padding="16,12"
            Visibility="{Binding InviteInProgress, Converter={StaticResource BoolToVis}}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" VerticalAlignment="Center">
          <TextBlock Text="{DynamicResource S.clip.peers.invitePinLabel}" FontSize="12.5" Foreground="{DynamicResource Accent}" />
          <TextBlock Text="{Binding PendingPin}" FontSize="30" FontWeight="Bold" FontFamily="Consolas" Foreground="{DynamicResource Accent}" Margin="0,2,0,0" />
          <TextBlock Text="{Binding PendingPeerText}" FontSize="12.5" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0" />
        </StackPanel>
        <Button Grid.Column="1" Content="{DynamicResource S.clip.peers.cancelInvite}" Style="{StaticResource MiniButton}"
                VerticalAlignment="Center" Command="{Binding CancelInviteCommand}" />
      </Grid>
    </Border>

    <!-- discovered peers + active links -->
    <Grid Grid.Row="2" Margin="0,12,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- discovered -->
      <Border Grid.Column="0" Style="{StaticResource Card}" Padding="2" Margin="0,0,6,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <StackPanel Grid.Row="0">
            <TextBlock Text="{DynamicResource S.clip.peers.discovered}" FontSize="12.5" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondary}" Margin="14,11,0,6" />
            <!-- manual connect by IP — guaranteed path when auto-discovery is blocked (AP isolation / multicast filtering) -->
            <TextBlock Text="{DynamicResource S.clip.peers.manualHint}" FontSize="11" Foreground="{DynamicResource TextTertiary}"
                       Margin="14,0,12,5" TextWrapping="Wrap" />
            <DockPanel Margin="12,0,12,8">
              <Button DockPanel.Dock="Right" Content="{DynamicResource S.clip.peers.manualConnect}" Style="{StaticResource InfoButton}"
                      Margin="6,0,0,0" Command="{Binding ConnectManualCommand}" />
              <TextBox DockPanel.Dock="Right" Width="56" Text="{Binding ManualPort}" Padding="6,5" Margin="6,0,0,0" VerticalContentAlignment="Center" />
              <TextBox Text="{Binding ManualIp, UpdateSourceTrigger=PropertyChanged}" Padding="8,5" VerticalContentAlignment="Center"
                       Tag="{DynamicResource S.clip.peers.manualPlaceholder}" />
            </DockPanel>
          </StackPanel>
          <TextBlock Grid.Row="1" Text="{DynamicResource S.clip.peers.none}" FontSize="13" Foreground="{DynamicResource TextTertiary}"
                     Margin="14,2,14,0" TextWrapping="Wrap" VerticalAlignment="Top"
                     Visibility="{Binding NoPeers, Converter={StaticResource BoolToVis}}" />
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding DiscoveredPeers}" Margin="6,0,6,6">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="{DynamicResource PageBg}" CornerRadius="8" Padding="11,9" Margin="0,0,0,6">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DeviceName}" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                        <TextBlock FontSize="11.5" Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0">
                          <Run Text="{Binding Address, Mode=OneWay}" /><Run Text="   " /><Run Text="{Binding Version, Mode=OneWay}" />
                        </TextBlock>
                      </StackPanel>
                      <Button Grid.Column="1" Content="{Binding ActionText}" Style="{StaticResource InfoButton}"
                              VerticalAlignment="Center" Command="{Binding InviteCommand}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>

      <!-- active links -->
      <Border Grid.Column="1" Style="{StaticResource Card}" Padding="2" Margin="6,0,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Text="{DynamicResource S.clip.peers.active}" FontSize="12.5" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextSecondary}" Margin="14,11,0,8" />
          <TextBlock Grid.Row="1" Text="{DynamicResource S.clip.peers.noActive}" FontSize="13" Foreground="{DynamicResource TextTertiary}"
                     Margin="14,2,14,0" TextWrapping="Wrap" VerticalAlignment="Top"
                     Visibility="{Binding NoLinks, Converter={StaticResource BoolToVis}}" />
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ActiveLinks}" Margin="6,0,6,6">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="{DynamicResource OkBg}" CornerRadius="8" Padding="11,9" Margin="0,0,0,6">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PeerName}" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                        <TextBlock FontSize="11.5" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0">
                          <Run Text="{Binding Remote, Mode=OneWay}" /><Run Text="   " /><Run Text="{Binding Role, Mode=OneWay}" /><Run Text="   " /><Run Text="{Binding SinceText, Mode=OneWay}" />
                        </TextBlock>
                      </StackPanel>
                      <Button Grid.Column="1" Content="{DynamicResource S.clip.peers.disconnect}" Style="{StaticResource DangerButton}"
                              VerticalAlignment="Center" Command="{Binding DisconnectCommand}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>

    <!-- log -->
    <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0" Margin="0,12,0,0" Height="140">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" Margin="12,8,12,4">
          <Button DockPanel.Dock="Right" Content="{DynamicResource S.clip.peers.clearLog}" Style="{StaticResource MiniButton}" Command="{Binding ClearLogCommand}" />
          <TextBlock Text="{DynamicResource S.clip.peers.log}" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
        </DockPanel>
        <TextBox x:Name="LogBox" Grid.Row="1" Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True"
                 FontFamily="Consolas" FontSize="11.5" BorderThickness="0" Background="Transparent"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap" Margin="6,0,2,6" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
