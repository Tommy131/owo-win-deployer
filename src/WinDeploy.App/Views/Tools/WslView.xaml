<UserControl x:Class="WinDeploy.App.Views.Tools.WslView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="{DynamicResource S.wsl.title}" FontSize="20" FontWeight="SemiBold" />
      <TextBlock Text="{DynamicResource S.wsl.subtitle}"
                 FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0" TextWrapping="Wrap" />
    </StackPanel>

    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
      <Button Content="{DynamicResource S.common.refresh}" Style="{StaticResource MiniButton}" Command="{Binding RefreshCommand}" />
      <Button Content="{DynamicResource S.wsl.btn.shutdownAll}" Style="{StaticResource MiniButton}" Margin="8,0,0,0" Command="{Binding ShutdownCommand}"
              Visibility="{Binding FeatureEnabled, Converter={StaticResource BoolToVis}}" />
      <TextBlock Text="{Binding Note}" FontSize="12" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" Margin="14,0,0,0"
                 TextWrapping="Wrap" MaxWidth="520" />
    </StackPanel>

    <!-- Install row (only when the WSL feature is enabled) -->
    <Border Grid.Row="2" Style="{StaticResource Card}" Padding="14,11" Margin="0,12,0,0"
            Visibility="{Binding FeatureEnabled, Converter={StaticResource BoolToVis}}">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="{DynamicResource S.wsl.install.label}" FontSize="13" VerticalAlignment="Center" />
        <ComboBox Width="240" Height="30" Margin="8,0,0,0" ItemsSource="{Binding Online}" SelectedItem="{Binding SelectedOnline}"
                  DisplayMemberPath="Friendly" VerticalAlignment="Center" />
        <Button Content="{DynamicResource S.wsl.btn.install}" Style="{StaticResource InfoButton}" Margin="8,0,0,0" Command="{Binding InstallCommand}" />
        <TextBlock Text="{DynamicResource S.wsl.install.hint}" FontSize="11" Foreground="{DynamicResource TextTertiary}"
                   VerticalAlignment="Center" Margin="10,0,0,0" />
      </StackPanel>
    </Border>

    <!-- Margin right -24 / Padding right 24: scrollbar flush at the page's outer edge, content unchanged. -->
    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,12,-24,0" Padding="0,0,24,0">
      <StackPanel>
        <!-- WSL 功能未启用：先去控制面板启用 -->
        <Border Style="{StaticResource Card}" Padding="18,16" Margin="0,2,0,0"
                Visibility="{Binding FeatureDisabled, Converter={StaticResource BoolToVis}}">
          <StackPanel>
            <TextBlock Text="{DynamicResource S.wsl.feature.disabled.title}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource WarnFg}" />
            <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,8,0,0"
                       Text="{DynamicResource S.wsl.feature.disabled.body}" />
            <TextBlock TextWrapping="Wrap" FontSize="13" Margin="0,10,0,0" LineHeight="22"
                       Text="{DynamicResource S.wsl.feature.disabled.steps}" />
            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
              <Button Content="{DynamicResource S.wsl.btn.openFeatures}" Style="{StaticResource PrimaryButton}" Command="{Binding OpenFeaturesCommand}" />
              <Button Content="{DynamicResource S.wsl.btn.enableFeature}" Style="{StaticResource MiniButton}" Margin="8,0,0,0" Command="{Binding EnableFeatureCommand}" />
              <Button Content="{DynamicResource S.wsl.btn.refreshDetect}" Style="{StaticResource MiniButton}" Margin="8,0,0,0" Command="{Binding RefreshCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>
        <ItemsControl ItemsSource="{Binding Distros}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Style="{StaticResource Card}" Padding="14,11" Margin="0,0,0,8">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                      <Border CornerRadius="6" Padding="6,1" Margin="8,0,0,0" Background="{DynamicResource AccentBg}" VerticalAlignment="Center"
                              Visibility="{Binding IsDefault, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource S.wsl.badge.default}" FontSize="10" Foreground="{DynamicResource Accent}" />
                      </Border>
                      <Border CornerRadius="6" Padding="6,1" Margin="5,0,0,0" Background="{DynamicResource OkBg}" VerticalAlignment="Center"
                              Visibility="{Binding Running, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource S.wsl.badge.running}" FontSize="10" Foreground="{DynamicResource OkFg}" />
                      </Border>
                    </StackPanel>
                    <TextBlock FontSize="11.5" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0">
                      <Run Text="{Binding State, Mode=OneWay}" /><Run Text="  ·  " /><Run Text="{Binding Version, Mode=OneWay}" />
                    </TextBlock>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{DynamicResource S.common.start}" Style="{StaticResource OkButton}"
                            Command="{Binding DataContext.LaunchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" />
                    <Button Content="{DynamicResource S.wsl.distro.setDefault}" Style="{StaticResource MiniButton}" Margin="6,0,0,0"
                            Command="{Binding DataContext.SetDefaultCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" />
                    <Button Content="{DynamicResource S.common.stop}" Style="{StaticResource MiniButton}" Margin="6,0,0,0"
                            Command="{Binding DataContext.TerminateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" />
                    <Button Content="{DynamicResource S.wsl.distro.export}" Style="{StaticResource MiniButton}" Margin="6,0,0,0"
                            Command="{Binding DataContext.ExportCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" />
                    <Button Content="{DynamicResource S.wsl.distro.unregister}" Style="{StaticResource DangerButton}" Margin="6,0,0,0"
                            Command="{Binding DataContext.UnregisterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" />
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
