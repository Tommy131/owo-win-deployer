<UserControl x:Class="WinDeploy.App.Views.Tools.TweaksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="{DynamicResource S.tweaks.title}" FontSize="20" FontWeight="SemiBold" />
      <TextBlock Text="{DynamicResource S.tweaks.subtitle}"
                 FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0" TextWrapping="Wrap" />
    </StackPanel>

    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
      <Button Content="{DynamicResource S.tweaks.refresh}" Style="{StaticResource MiniButton}" Command="{Binding RefreshCommand}" />
    </StackPanel>

    <!-- Margin right -24 / Padding right 24: scrollbar flush at the page's outer edge, content unchanged. -->
    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,12,-24,0" Padding="0,0,24,0">
      <ItemsControl ItemsSource="{Binding Tweaks}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Style="{StaticResource Card}" Padding="14,11" Margin="0,0,0,8">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border CornerRadius="6" Padding="6,1" Margin="8,0,0,0" Background="{DynamicResource WarnBg}" VerticalAlignment="Center"
                            Visibility="{Binding NeedsAdmin, Converter={StaticResource BoolToVis}}">
                      <TextBlock Text="{DynamicResource S.tweaks.badge.needsAdmin}" FontSize="10" Foreground="{DynamicResource WarnFg}" />
                    </Border>
                  </StackPanel>
                  <TextBlock Text="{Binding Detail}" FontSize="11.5" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0" TextWrapping="Wrap" />
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding StateText}" FontSize="12" Foreground="{DynamicResource TextTertiary}"
                           VerticalAlignment="Center" Margin="0,0,12,0" />
                <Button Grid.Column="2" Content="{Binding ToggleLabel}" Style="{StaticResource InfoButton}" VerticalAlignment="Center" MinWidth="56"
                        Command="{Binding DataContext.ToggleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}" />
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
