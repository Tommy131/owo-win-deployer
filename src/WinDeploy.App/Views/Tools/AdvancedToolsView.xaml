<UserControl x:Class="WinDeploy.App.Views.Tools.AdvancedToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="{DynamicResource S.advtools.title}" FontSize="20" FontWeight="SemiBold" />
      <TextBlock Text="{DynamicResource S.advtools.subtitle}"
                 FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0" TextWrapping="Wrap" />
    </StackPanel>

    <WrapPanel Grid.Row="1" Margin="0,14,0,0">
      <Button Content="{DynamicResource S.advtools.btn.doctor}" Style="{StaticResource InfoButton}" Margin="0,0,8,8" Command="{Binding DoctorCommand}" />
      <Button Content="{DynamicResource S.advtools.btn.validate}" Style="{StaticResource InfoButton}" Margin="0,0,8,8" Command="{Binding ValidateCommand}" />
      <Button Content="{DynamicResource S.advtools.btn.lock}" Style="{StaticResource InfoButton}" Margin="0,0,8,8" Command="{Binding LockCommand}" />
      <Button Content="{DynamicResource S.advtools.btn.dsc}" Style="{StaticResource InfoButton}" Margin="0,0,8,8" Command="{Binding DscCommand}" />
      <Button Content="{DynamicResource S.advtools.btn.offline}" Style="{StaticResource InfoButton}" Margin="0,0,8,8" Command="{Binding OfflineCommand}" />
      <Button Content="{DynamicResource S.advtools.btn.migrateExport}" Style="{StaticResource InfoButton}" Margin="0,0,8,8" Command="{Binding MigrateExportCommand}" />
      <Button Content="{DynamicResource S.advtools.btn.migrateImport}" Style="{StaticResource InfoButton}" Margin="0,0,8,8" Command="{Binding MigrateImportCommand}" />
      <Button Content="{DynamicResource S.advtools.btn.editHosts}" Style="{StaticResource MiniButton}" Margin="0,0,8,8" Command="{Binding EditHostsCommand}" />
      <Button Content="{DynamicResource S.advtools.btn.clear}" Style="{StaticResource MiniButton}" Margin="0,0,8,8" Command="{Binding ClearCommand}" />
    </WrapPanel>

    <Border Grid.Row="2" Style="{StaticResource Card}" Padding="2" Margin="0,4,0,0">
      <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
        <TextBox Text="{Binding Output, Mode=OneWay}" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                 FontFamily="Consolas" FontSize="12.5" TextWrapping="Wrap" VerticalScrollBarVisibility="Disabled" />
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>
