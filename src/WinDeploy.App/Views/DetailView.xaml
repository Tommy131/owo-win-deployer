<UserControl x:Class="WinDeploy.App.Views.DetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Button Grid.Row="0" Content="← 返回" Command="{Binding BackCommand}"
            HorizontalAlignment="Left" Style="{StaticResource PrimaryButton}" />

    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,16,0,0">
      <Grid Width="56" Height="56">
        <Border CornerRadius="12" Background="{Binding ChipBackground}"
                Visibility="{Binding ShowLetter, Converter={StaticResource BoolToVis}}">
          <TextBlock Text="{Binding Badge}" FontSize="26" FontWeight="SemiBold" Foreground="{Binding ChipForeground}"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <Image Source="{Binding IconImage}" Stretch="Uniform" Margin="3"
               Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}"
               RenderOptions.BitmapScalingMode="HighQuality" />
      </Grid>
      <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="{Binding Name}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
          <Border CornerRadius="10" Padding="9,2" Margin="10,0,0,0" VerticalAlignment="Center" Background="{DynamicResource PageBg}">
            <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="{DynamicResource TextSecondary}" />
          </Border>
        </StackPanel>
        <TextBlock Text="{Binding Summary}" FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0" />
      </StackPanel>
    </StackPanel>

    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
     <StackPanel>
      <Border Style="{StaticResource Card}" Padding="18">
       <StackPanel>
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="版本" FontSize="13" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
          <StackPanel Grid.Column="1" Orientation="Horizontal"
                      Visibility="{Binding CanChooseVersion, Converter={StaticResource BoolToVis}}">
            <ComboBox ItemsSource="{Binding Versions}" SelectedItem="{Binding SelectedVersion}" Width="180"
                      ToolTip="选择要安装的版本（默认最新）" />
            <TextBlock Text="{Binding InstalledNote}" FontSize="12" Foreground="{DynamicResource TextTertiary}"
                       VerticalAlignment="Center" Margin="10,0,0,0" />
          </StackPanel>
          <TextBlock Grid.Column="1" Text="{Binding Version}" FontSize="13" VerticalAlignment="Center"
                     Visibility="{Binding CannotChooseVersion, Converter={StaticResource BoolToVis}}" />
        </Grid>
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="大小" FontSize="13" Foreground="{DynamicResource TextSecondary}" />
          <TextBlock Grid.Column="1" Text="{Binding Size}" FontSize="13" />
        </Grid>
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="安装日期" FontSize="13" Foreground="{DynamicResource TextSecondary}" />
          <TextBlock Grid.Column="1" Text="{Binding InstallDate}" FontSize="13" />
        </Grid>
        <Grid Margin="0,0,0,12" Visibility="{Binding HasInstallLocation, Converter={StaticResource BoolToVis}}">
          <Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="安装位置" FontSize="13" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
          <StackPanel Grid.Column="1" Orientation="Horizontal">
            <TextBlock Text="{Binding InstallLocation}" FontSize="13" FontFamily="Consolas" TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center" MaxWidth="300" ToolTip="{Binding InstallLocation}" />
            <Button Content="打开" Style="{StaticResource MiniButton}" Command="{Binding OpenLocationCommand}" Margin="10,0,0,0" />
          </StackPanel>
        </Grid>
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="发布者" FontSize="13" Foreground="{DynamicResource TextSecondary}" />
          <TextBlock Grid.Column="1" Text="{Binding Publisher}" FontSize="13" TextTrimming="CharacterEllipsis" />
        </Grid>
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="来源" FontSize="13" Foreground="{DynamicResource TextSecondary}" />
          <TextBlock Grid.Column="1" Text="{Binding Source}" FontSize="13" />
        </Grid>
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="标识" FontSize="13" Foreground="{DynamicResource TextSecondary}" />
          <TextBlock Grid.Column="1" Text="{Binding PackageId}" FontSize="13" FontFamily="Consolas" TextTrimming="CharacterEllipsis" />
        </Grid>
        <Grid>
          <Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="官网" FontSize="13" Foreground="{DynamicResource TextSecondary}" />
          <TextBlock Grid.Column="1" FontSize="13" TextTrimming="CharacterEllipsis">
            <Hyperlink Command="{Binding OpenHomepageCommand}"><Run Text="{Binding Homepage, Mode=OneWay}" /></Hyperlink>
          </TextBlock>
        </Grid>
       </StackPanel>
      </Border>

      <Border Style="{StaticResource Card}" Padding="18" Margin="0,14,0,0">
        <StackPanel>
          <TextBlock Text="操作" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10" />

          <StackPanel Margin="0,0,0,12" Visibility="{Binding CanSetPath, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="安装路径" FontSize="12" Foreground="{DynamicResource TextSecondary}" />
            <TextBox Text="{Binding InstallPath, UpdateSourceTrigger=PropertyChanged}" Height="32" VerticalContentAlignment="Center" Padding="8,0" Margin="0,3,0,0" />
            <TextBlock Text="{Binding PathHint}" FontSize="11" Foreground="{DynamicResource TextTertiary}" Margin="0,3,0,0" TextWrapping="Wrap" />
          </StackPanel>

          <!-- 运行：启动（绿）/ 结束进程（红，仅运行时）/ 重启（蓝） -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,10" Visibility="{Binding CanLaunch, Converter={StaticResource BoolToVis}}">
            <Button Content="▶ 启动" Style="{StaticResource OkButton}" Command="{Binding LaunchCommand}" ToolTip="启动该软件" />
            <Button Content="■ 结束进程" Style="{StaticResource DangerButton}" Command="{Binding StopCommand}" Margin="8,0,0,0"
                    Visibility="{Binding CanStop, Converter={StaticResource BoolToVis}}" ToolTip="结束该软件的所有进程" />
            <Button Content="↻ 重启" Style="{StaticResource InfoButton}" Command="{Binding RestartCommand}" Margin="8,0,0,0" ToolTip="结束后重新启动" />
          </StackPanel>

          <!-- 管理：安装 / 检查更新（蓝）/ 降级 / 卸载（红） · 随版本选择器联动 -->
          <StackPanel Orientation="Horizontal">
            <Button Content="安装" Style="{StaticResource PrimaryButton}" Command="{Binding InstallCommand}"
                    Visibility="{Binding ShowInstall, Converter={StaticResource BoolToVis}}" ToolTip="按所选版本安装该软件" />
            <Button Content="检查 / 更新" Style="{StaticResource InfoButton}" Command="{Binding UpdateCommand}"
                    Visibility="{Binding ShowUpdate, Converter={StaticResource BoolToVis}}"
                    ToolTip="winget upgrade / git pull / 便携包重拉，更新到最新版本" />
            <Button Content="降级" Style="{StaticResource MiniButton}" Command="{Binding DowngradeCommand}" Margin="8,0,0,0"
                    Visibility="{Binding ShowDowngrade, Converter={StaticResource BoolToVis}}"
                    ToolTip="安装所选的较低版本（仅 winget）" />
            <Button Content="卸载…" Style="{StaticResource DangerButton}" Command="{Binding UninstallCommand}" Margin="8,0,0,0"
                    Visibility="{Binding CanUninstall, Converter={StaticResource BoolToVis}}" ToolTip="卸载该软件" />
          </StackPanel>
        </StackPanel>
      </Border>
     </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
